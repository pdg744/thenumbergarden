---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Membership"
  description="Membership details for The Number Garden."
>
  <meta http-equiv="refresh" content="0;url=/membership/" />
  <section class="panel panel-light contact-panel">
    <div class="section-heading">
      <p class="eyebrow">Redirecting</p>
      <h1>Membership has moved.</h1>
    </div>
    <p class="contact-copy">
      You can find current membership details at
      <a class="card-link" href="/membership/"> /membership/</a>.
    </p>
  </section>
</BaseLayout>
