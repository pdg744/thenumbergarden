---
import BaseLayout from "../layouts/BaseLayout.astro";
import { logoIntroConfig } from "../config/brand.js";
import { logoIntroAspectPresets } from "../lib/video/logoIntroRenderer.js";

const { animation, initialGeometry, finalGeometry } = logoIntroConfig;
---

<BaseLayout
  title="Video Intro Lab"
  description="A tuning bench for The Number Garden logo intro animation."
  noindex
>
  <section class="intro-lab panel panel-light">
    <div class="lab-copy">
      <p class="eyebrow">Video Intro Lab</p>
      <h1>Logo growth animation</h1>
      <p>
        Author the initial dot-talk state and final logo state here, then copy
        the matching Manim config for the YouTube intro render.
      </p>
    </div>

    <div class="lab-workbench" data-video-intro-lab>
      <div class="preview-panel">
        <div class="still-grid" aria-label="Endpoint previews">
          <figure class="still-card">
            <figcaption>Start</figcaption>
            <div class="still-surface" data-start-preview></div>
          </figure>
          <figure class="still-card">
            <figcaption>End</figcaption>
            <div class="still-surface" data-end-preview></div>
          </figure>
        </div>
        <div class="preview-surface" data-preview></div>
        <div class="aspect-controls" aria-label="Composition aspect ratio">
          {logoIntroAspectPresets.map((preset, index) => (
            <button
              class:list={["aspect-button", index === 0 && "is-active"]}
              type="button"
              data-aspect-preset={preset.id}
              aria-pressed={index === 0 ? "true" : "false"}
            >
              <span>{preset.shortLabel}</span>
              {preset.label}
            </button>
          ))}
        </div>
        <div class="preview-actions">
          <button class="lab-button lab-button-primary" type="button" data-replay>Replay</button>
          <button class="lab-button" type="button" data-copy-export-command>Copy Export Command</button>
          <button class="lab-button" type="button" data-copy-config>Copy Manim Config</button>
        </div>
      </div>

      <form class="control-panel" aria-label="Video intro animation controls">
        <fieldset>
          <legend>Timing</legend>
          <label>
            <span>Transition time <output data-output-for="transitionDuration">{animation.transitionDuration}</output>s</span>
            <input name="transitionDuration" type="range" min="1.2" max="6" step="0.1" value={animation.transitionDuration} />
          </label>
          <label>
            <span>Start edge opacity <output data-output-for="startGuideOpacity">{animation.startGuideOpacity}</output></span>
            <input name="startGuideOpacity" type="range" min="0" max="1" step="0.01" value={animation.startGuideOpacity} />
          </label>
        </fieldset>

        <fieldset>
          <legend>Dot Talk Start</legend>
          <label>
            <span>Start outer radius <output data-output-for="startOuterRadius">{initialGeometry.outerRadius}</output></span>
            <input name="startOuterRadius" type="range" min="40" max="130" step="0.5" value={initialGeometry.outerRadius} />
            <div class="endpoint-track" data-endpoint-track="startOuterRadius" aria-hidden="true"></div>
          </label>
          <label>
            <span>Start dot radius <output data-output-for="startCircleRadius">{initialGeometry.circleRadius}</output></span>
            <input name="startCircleRadius" type="range" min="1.5" max="9" step="0.1" value={initialGeometry.circleRadius} />
            <div class="endpoint-track" data-endpoint-track="startCircleRadius" aria-hidden="true"></div>
          </label>
          <label>
            <span>Start rotation <output data-output-for="startRotation">{initialGeometry.rotation}</output></span>
            <input name="startRotation" type="range" min="-180" max="180" step="1" value={initialGeometry.rotation} />
            <div class="endpoint-track" data-endpoint-track="startRotation" aria-hidden="true"></div>
          </label>
          <label>
            <span>Start ring twist <output data-output-for="startRingTwist">{initialGeometry.ringTwist}</output></span>
            <input name="startRingTwist" type="range" min="-72" max="72" step="1" value={initialGeometry.ringTwist} />
            <div class="endpoint-track" data-endpoint-track="startRingTwist" aria-hidden="true"></div>
          </label>
        </fieldset>

        <fieldset>
          <legend>Final Mark</legend>
          <label>
            <span>Final first radius <output data-output-for="finalFirstRadius">{finalGeometry.firstRadius}</output></span>
            <input name="finalFirstRadius" type="range" min="4" max="36" step="0.1" value={finalGeometry.firstRadius} />
            <div class="endpoint-track" data-endpoint-track="finalFirstRadius" aria-hidden="true"></div>
          </label>
          <label>
            <span>Final spacing <output data-output-for="finalSpacing">{finalGeometry.spacing}</output></span>
            <input name="finalSpacing" type="range" min="6" max="30" step="0.1" value={finalGeometry.spacing} />
            <div class="endpoint-track" data-endpoint-track="finalSpacing" aria-hidden="true"></div>
          </label>
          <label>
            <span>Outer spacing <output data-output-for="finalOuterSpacing">{finalGeometry.outerSpacing}</output></span>
            <input name="finalOuterSpacing" type="range" min="6" max="30" step="0.1" value={finalGeometry.outerSpacing} />
            <div class="endpoint-track" data-endpoint-track="finalOuterSpacing" aria-hidden="true"></div>
          </label>
          <label>
            <span>Final dot radius <output data-output-for="finalCircleRadius">{finalGeometry.circleRadius}</output></span>
            <input name="finalCircleRadius" type="range" min="3" max="24" step="0.1" value={finalGeometry.circleRadius} />
            <div class="endpoint-track" data-endpoint-track="finalCircleRadius" aria-hidden="true"></div>
          </label>
          <label>
            <span>Middle dot radius <output data-output-for="finalMiddleCircleRadius">{finalGeometry.middleCircleRadius}</output></span>
            <input name="finalMiddleCircleRadius" type="range" min="3" max="24" step="0.1" value={finalGeometry.middleCircleRadius} />
            <div class="endpoint-track" data-endpoint-track="finalMiddleCircleRadius" aria-hidden="true"></div>
          </label>
          <label>
            <span>Outer dot radius <output data-output-for="finalOuterCircleRadius">{finalGeometry.outerCircleRadius}</output></span>
            <input name="finalOuterCircleRadius" type="range" min="3" max="24" step="0.1" value={finalGeometry.outerCircleRadius} />
            <div class="endpoint-track" data-endpoint-track="finalOuterCircleRadius" aria-hidden="true"></div>
          </label>
          <label>
            <span>Overshoot <output data-output-for="overshootScale">{animation.overshootScale}</output></span>
            <input name="overshootScale" type="range" min="1" max="1.35" step="0.01" value={animation.overshootScale} />
          </label>
          <label>
            <span>Guide opacity <output data-output-for="guideOpacity">{animation.guideOpacity}</output></span>
            <input name="guideOpacity" type="range" min="0" max="1" step="0.01" value={animation.guideOpacity} />
          </label>
          <label class="toggle-row">
            <span>Show wordmark</span>
            <input name="showWordmark" type="checkbox" checked={logoIntroConfig.text.showWordmark} />
          </label>
        </fieldset>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  import { logoIntroConfig as introConfig } from "../config/brand.js";
  import {
    buildLogoIntroConfig,
    buildLogoIntroFrameSvg,
    getLogoIntroDuration,
    getLogoIntroPreset,
    logoIntroAspectPresets,
  } from "../lib/video/logoIntroRenderer.js";

  const lab = document.querySelector("[data-video-intro-lab]");
  const form = lab?.querySelector("form");
  const preview = lab?.querySelector("[data-preview]");
  const startPreview = lab?.querySelector("[data-start-preview]");
  const endPreview = lab?.querySelector("[data-end-preview]");
  const replayButton = lab?.querySelector("[data-replay]");
  const copyButton = lab?.querySelector("[data-copy-config]");
  const copyExportCommandButton = lab?.querySelector("[data-copy-export-command]");
  const aspectButtons = Array.from(lab?.querySelectorAll("[data-aspect-preset]") ?? []);
  const formatter = new Intl.NumberFormat("en-US", { maximumFractionDigits: 3 });
  let activePreset = logoIntroAspectPresets[0];
  let animationStart = performance.now();
  let rafId = 0;

  const finalOuterRadius = (settings) =>
    settings.finalFirstRadius
    + (introConfig.finalGeometry.rings - 2) * settings.finalSpacing
    + settings.finalOuterSpacing;

  const clampPercent = (value) => Math.min(100, Math.max(0, value));

  const inputFor = (name) => form?.querySelector(`[name="${name}"]`);
  const clampToInput = (input, value) => {
    const min = Number(input.getAttribute("min"));
    const max = Number(input.getAttribute("max"));
    return Math.min(max, Math.max(min, value));
  };
  const snapToInputStep = (input, value) => {
    const min = Number(input.getAttribute("min"));
    const step = Number(input.getAttribute("step"));
    if (!Number.isFinite(step) || step <= 0) {
      return value;
    }

    return min + Math.round((value - min) / step) * step;
  };
  const setInputValue = (name, value) => {
    const input = inputFor(name);
    if (!input) {
      return;
    }
    input.value = String(clampToInput(input, snapToInputStep(input, value)));
  };

  const overlayBindings = {
    startOuterRadius: {
      role: "end",
      value: finalOuterRadius,
      set: (value) => {
        const outerSpacing = value - settingsFromForm().finalFirstRadius - (introConfig.finalGeometry.rings - 2) * settingsFromForm().finalSpacing;
        setInputValue("finalOuterSpacing", outerSpacing);
      },
    },
    startCircleRadius: {
      role: "end",
      value: (settings) => settings.finalCircleRadius,
      set: (value) => setInputValue("finalCircleRadius", value),
    },
    finalFirstRadius: {
      role: "start",
      value: (settings) => settings.startOuterRadius / introConfig.finalGeometry.rings,
      set: (value) => setInputValue("startOuterRadius", value * introConfig.finalGeometry.rings),
    },
    finalSpacing: {
      role: "start",
      value: (settings) => settings.startOuterRadius / introConfig.finalGeometry.rings,
      set: (value) => setInputValue("startOuterRadius", value * introConfig.finalGeometry.rings),
    },
    finalOuterSpacing: {
      role: "start",
      value: (settings) => settings.startOuterRadius / introConfig.finalGeometry.rings,
      set: (value) => setInputValue("startOuterRadius", value * introConfig.finalGeometry.rings),
    },
    finalCircleRadius: {
      role: "start",
      value: (settings) => settings.startCircleRadius,
      set: (value) => setInputValue("startCircleRadius", value),
    },
    finalMiddleCircleRadius: {
      role: "start",
      value: (settings) => settings.startCircleRadius,
      set: (value) => setInputValue("startCircleRadius", value),
    },
    finalOuterCircleRadius: {
      role: "start",
      value: (settings) => settings.startCircleRadius,
      set: (value) => setInputValue("startCircleRadius", value),
    },
  };

  const settingsFromForm = () => {
    const data = new FormData(form);
    return {
      transitionDuration: Number(data.get("transitionDuration")),
      startGuideOpacity: Number(data.get("startGuideOpacity")),
      startOuterRadius: Number(data.get("startOuterRadius")),
      startCircleRadius: Number(data.get("startCircleRadius")),
      startRotation: Number(data.get("startRotation")),
      startRingTwist: Number(data.get("startRingTwist")),
      finalFirstRadius: Number(data.get("finalFirstRadius")),
      finalSpacing: Number(data.get("finalSpacing")),
      finalOuterSpacing: Number(data.get("finalOuterSpacing")),
      finalCircleRadius: Number(data.get("finalCircleRadius")),
      finalMiddleCircleRadius: Number(data.get("finalMiddleCircleRadius")),
      finalOuterCircleRadius: Number(data.get("finalOuterCircleRadius")),
      overshootScale: Number(data.get("overshootScale")),
      guideOpacity: Number(data.get("guideOpacity")),
      showWordmark: data.get("showWordmark") === "on",
    };
  };

  const readSettings = settingsFromForm;

  const updateOutputs = (settings) => {
    for (const [key, value] of Object.entries(settings)) {
      const output = lab?.querySelector(`[data-output-for="${key}"]`);
      if (output && typeof value === "number") {
        output.textContent = formatter.format(value);
      }
    }
  };

  const updateEndpointTracks = (settings) => {
    const startSpacing = settings.startOuterRadius / introConfig.finalGeometry.rings;
    const endpoints = {
      startOuterRadius: [settings.startOuterRadius, finalOuterRadius(settings)],
      startCircleRadius: [settings.startCircleRadius, settings.finalCircleRadius],
      startRotation: [settings.startRotation, introConfig.finalGeometry.rotation],
      startRingTwist: [settings.startRingTwist, introConfig.finalGeometry.ringTwist],
      finalFirstRadius: [startSpacing, settings.finalFirstRadius],
      finalSpacing: [startSpacing, settings.finalSpacing],
      finalOuterSpacing: [startSpacing, settings.finalOuterSpacing],
      finalCircleRadius: [settings.startCircleRadius, settings.finalCircleRadius],
      finalMiddleCircleRadius: [settings.startCircleRadius, settings.finalMiddleCircleRadius],
      finalOuterCircleRadius: [settings.startCircleRadius, settings.finalOuterCircleRadius],
    };

    for (const [key, [startValue, endValue]] of Object.entries(endpoints)) {
      const track = lab?.querySelector(`[data-endpoint-track="${key}"]`);
      const input = form?.querySelector(`[name="${key}"]`);
      if (!track || !input) {
        continue;
      }

      const min = Number(input.getAttribute("min"));
      const max = Number(input.getAttribute("max"));
      const range = max - min || 1;
      const startPosition = clampPercent(((startValue - min) / range) * 100);
      const endPosition = clampPercent(((endValue - min) / range) * 100);
      const isFinalControl = key.startsWith("final");
      const overlayBinding = overlayBindings[key];
      const primaryRole = isFinalControl ? "end" : "start";

      input.dataset.endpointRole = primaryRole;

      let rail = track.querySelector(".endpoint-rail");
      if (!rail) {
        rail = document.createElement("div");
        rail.className = "endpoint-rail";
        rail.innerHTML = `
          <button class="endpoint-handle endpoint-handle-start" type="button" data-endpoint-role="start" aria-label="Start value"></button>
          <button class="endpoint-handle endpoint-handle-end" type="button" data-endpoint-role="end" aria-label="End value"></button>
        `;
        track.append(rail);

        rail.querySelectorAll(".endpoint-handle").forEach((handle) => {
          const applyDragValue = (clientX) => {
            const rect = rail.getBoundingClientRect();
            const percent = Math.min(1, Math.max(0, (clientX - rect.left) / rect.width));
            const nextValue = min + percent * range;
            const role = handle.dataset.endpointRole;
            if (role === primaryRole) {
              setInputValue(key, nextValue);
            } else {
              overlayBinding?.set(nextValue);
            }
            render();
          };

          handle.addEventListener("pointerdown", (event) => {
            event.preventDefault();
            handle.setPointerCapture(event.pointerId);
            const applyPointer = (pointerEvent) => {
              applyDragValue(pointerEvent.clientX);
            };
            const stopDrag = () => {
              handle.removeEventListener("pointermove", applyPointer);
              handle.removeEventListener("pointerup", stopDrag);
              handle.removeEventListener("pointercancel", stopDrag);
            };

            applyPointer(event);
            handle.addEventListener("pointermove", applyPointer);
            handle.addEventListener("pointerup", stopDrag);
            handle.addEventListener("pointercancel", stopDrag);
          });

          handle.addEventListener("mousedown", (event) => {
            event.preventDefault();
            const applyMouse = (mouseEvent) => {
              applyDragValue(mouseEvent.clientX);
            };
            const stopDrag = () => {
              document.removeEventListener("mousemove", applyMouse);
              document.removeEventListener("mouseup", stopDrag);
            };

            applyMouse(event);
            document.addEventListener("mousemove", applyMouse);
            document.addEventListener("mouseup", stopDrag);
          });
        });
      }

      rail.style.setProperty("--start-pos", `${startPosition}%`);
      rail.style.setProperty("--end-pos", `${endPosition}%`);
      rail.querySelector(".endpoint-handle-start").disabled = primaryRole !== "start" && !overlayBinding;
      rail.querySelector(".endpoint-handle-end").disabled = primaryRole !== "end" && !overlayBinding;

      let values = track.querySelector(".endpoint-values");
      if (!values) {
        values = document.createElement("div");
        values.className = "endpoint-values";
        values.innerHTML = `<span data-endpoint-label="start"></span><span data-endpoint-label="end"></span>`;
        track.append(values);
      }

      values.querySelector('[data-endpoint-label="start"]').textContent = `Start ${formatter.format(startValue)}`;
      values.querySelector('[data-endpoint-label="end"]').textContent = `End ${formatter.format(endValue)}`;

      track.style.setProperty("--start-pos", `${startPosition}%`);
      track.style.setProperty("--end-pos", `${endPosition}%`);
      track.style.setProperty("--range-start", `${Math.min(startPosition, endPosition)}%`);
      track.style.setProperty("--range-end", `${Math.max(startPosition, endPosition)}%`);
      track.classList.toggle("is-tight", Math.abs(startPosition - endPosition) < 8);
      track.dataset.startValue = formatter.format(startValue);
      track.dataset.endValue = formatter.format(endValue);
    }
  };

  const frameSvg = (settings, elapsed, preset = activePreset) =>
    buildLogoIntroFrameSvg({ introConfig, settings, preset, elapsed });

  const buildStaticSvg = (settings, elapsed) =>
    frameSvg(settings, elapsed, getLogoIntroPreset("square-1x1"));

  const updatePreviewRatio = () => {
    preview?.style.setProperty("--preview-aspect", `${activePreset.width} / ${activePreset.height}`);
  };

  const setActivePreset = (presetId) => {
    activePreset = getLogoIntroPreset(presetId);
    for (const button of aspectButtons) {
      const isActive = button.dataset.aspectPreset === activePreset.id;
      button.classList.toggle("is-active", isActive);
      button.setAttribute("aria-pressed", isActive ? "true" : "false");
    }
    updatePreviewRatio();
  };

  const tick = () => {
    const settings = readSettings();
    const duration = getLogoIntroDuration(introConfig, settings);
    const elapsed = Math.min((performance.now() - animationStart) / 1000, duration);
    if (preview) {
      preview.innerHTML = frameSvg(settings, elapsed);
    }
    if (elapsed < duration) {
      rafId = window.requestAnimationFrame(tick);
    }
  };

  const replay = () => {
    window.cancelAnimationFrame(rafId);
    animationStart = performance.now();
    tick();
  };

  const render = () => {
    const settings = readSettings();
    updateOutputs(settings);
    updateEndpointTracks(settings);
    if (startPreview) {
      startPreview.innerHTML = buildStaticSvg(settings, 0);
    }
    if (endPreview) {
      endPreview.innerHTML = buildStaticSvg(settings, getLogoIntroDuration(introConfig, settings));
    }
    replay();
    return settings;
  };

  form?.addEventListener("input", render);
  form?.addEventListener("change", render);
  replayButton?.addEventListener("click", replay);
  aspectButtons.forEach((button) => {
    button.addEventListener("click", () => {
      setActivePreset(button.dataset.aspectPreset);
      render();
    });
  });
  copyButton?.addEventListener("click", async () => {
    await navigator.clipboard.writeText(JSON.stringify(buildLogoIntroConfig(introConfig, readSettings()), null, 2));
    copyButton.textContent = "Copied";
    window.setTimeout(() => {
      copyButton.textContent = "Copy Manim Config";
    }, 1200);
  });
  copyExportCommandButton?.addEventListener("click", async () => {
    const encodedSettings = btoa(JSON.stringify(readSettings()))
      .replace(/\+/g, "-")
      .replace(/\//g, "_")
      .replace(/=+$/, "");
    const command = `npm run video:intro:lab -- --preset=${activePreset.id} --settings=${encodedSettings}`;
    await navigator.clipboard.writeText(command);
    copyExportCommandButton.textContent = "Copied";
    window.setTimeout(() => {
      copyExportCommandButton.textContent = "Copy Export Command";
    }, 1200);
  });

  setActivePreset(activePreset.id);
  render();
</script>

<style>
  .intro-lab,
  .lab-copy {
    display: grid;
    gap: 1.4rem;
  }

  .lab-copy h1 {
    max-width: 12ch;
    font-size: clamp(2.5rem, 5vw, 4.6rem);
    line-height: 0.96;
  }

  .lab-copy p:last-child {
    margin: 0;
    max-width: 46rem;
    color: var(--muted);
  }

  .lab-workbench {
    display: grid;
    grid-template-columns: minmax(320px, 1fr) minmax(280px, 360px);
    gap: 1.2rem;
  }

  .preview-panel,
  .control-panel {
    border: 1px solid rgba(54, 84, 59, 0.14);
    border-radius: 22px;
    background: rgba(255, 250, 242, 0.72);
  }

  .preview-panel {
    display: grid;
    gap: 1rem;
    padding: 1rem;
  }

  .still-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .still-card {
    display: grid;
    gap: 0.45rem;
    margin: 0;
  }

  .still-card figcaption {
    color: var(--muted);
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .still-surface {
    display: grid;
    place-items: center;
    min-height: 210px;
    border-radius: 14px;
    background: var(--cream);
    box-shadow: inset 0 0 0 1px rgba(54, 84, 59, 0.1);
  }

  .still-surface :global(svg) {
    display: block;
    width: min(88%, 230px);
    height: auto;
  }

  .preview-surface {
    display: grid;
    place-items: center;
    min-height: 520px;
    aspect-ratio: var(--preview-aspect, 16 / 9);
    border-radius: 16px;
    background: var(--cream);
    box-shadow: inset 0 0 0 1px rgba(54, 84, 59, 0.1);
  }

  .preview-surface :global(svg) {
    display: block;
    width: 100%;
    height: 100%;
    max-height: 68vh;
    object-fit: contain;
  }

  .aspect-controls {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .aspect-button {
    display: grid;
    gap: 0.12rem;
    min-height: 3.3rem;
    padding: 0.55rem 0.65rem;
    border: 1px solid rgba(54, 84, 59, 0.14);
    border-radius: 8px;
    background: rgba(54, 84, 59, 0.06);
    color: var(--moss);
    font: inherit;
    font-size: 0.78rem;
    font-weight: 900;
    cursor: pointer;
  }

  .aspect-button span {
    color: var(--ink);
    font-size: 1rem;
  }

  .aspect-button.is-active {
    border-color: rgba(54, 84, 59, 0.4);
    background: var(--moss);
    color: var(--paper-inverse-strong);
  }

  .aspect-button.is-active span {
    color: var(--paper-inverse-strong);
  }

  .preview-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .lab-button {
    min-height: 2.8rem;
    padding: 0 1rem;
    border: 0;
    border-radius: 999px;
    background: rgba(54, 84, 59, 0.09);
    color: var(--moss);
    font: inherit;
    font-weight: 800;
    cursor: pointer;
  }

  .lab-button-primary {
    background: var(--moss);
    color: var(--paper-inverse-strong);
  }

  .control-panel {
    display: grid;
    gap: 1rem;
    padding: 1rem;
  }

  fieldset {
    display: grid;
    gap: 0.95rem;
    margin: 0;
    padding: 0 0 1rem;
    border: 0;
    border-bottom: 1px solid rgba(54, 84, 59, 0.12);
  }

  fieldset:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  legend {
    margin-bottom: 0.8rem;
    color: var(--ink);
    font-weight: 900;
  }

  label {
    display: grid;
    gap: 0.45rem;
    color: var(--muted);
    font-size: 0.94rem;
    font-weight: 800;
  }

  label > span {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  input[type="range"] {
    width: 100%;
    accent-color: var(--moss);
  }

  input[type="range"][data-endpoint-role="end"] {
    accent-color: var(--clay);
  }

  label:has(.endpoint-track) > input[type="range"] {
    display: none;
  }

  .endpoint-track {
    --start-pos: 0%;
    --end-pos: 100%;
    --range-start: 0%;
    --range-end: 100%;
    display: grid;
