---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";

const studioAddress = siteConfig.address.street;
const visitBookingUrl = siteConfig.familyVisitBookingUrl;
---

<BaseLayout
  title="Book a Family Visit"
  description="Book a free family visit at The Number Garden, a Portland math studio for tutoring, enrichment, confidence-building, and playful mathematical thinking."
>
  <Fragment slot="head">
    <link href={siteConfig.calendlyWidgetCssUrl} rel="stylesheet" />
    <script
      src={siteConfig.calendlyWidgetScriptUrl}
      type="text/javascript"
      data-calendly-widget-script
      async
    ></script>
  </Fragment>

  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Family Visit</p>
      <h1>See the studio before you decide.</h1>
      <p class="lede">
        A family visit is the clearest first step if you think The Number
        Garden might be a fit. It gives you a chance to see the space, meet
        Paul, and talk through what your child needs before making any bigger
        decision.
      </p>
      <div class="actions">
        <a
          class="button button-primary"
          href={visitBookingUrl}
          data-calendly-popup="family-visit"
        >
          Book a family visit
        </a>
      </div>
    </div>

    <aside class="hero-card" aria-label="Why book a family visit">
      <p class="card-label">Why start here</p>
      <ul>
        <li>See whether the studio feels right in person</li>
        <li>Talk about your child, your hopes, and your questions</li>
        <li>Get a feel for the tone, space, and pedagogy</li>
        <li>Leave with a clear sense of the best next step</li>
      </ul>
    </aside>
  </section>

  <section class="panel panel-light">
    <div class="section-heading">
      <p class="eyebrow">Before You Book</p>
      <h2>What the visit includes.</h2>
    </div>
    <div class="card-grid" aria-label="Family visit details">
      <article class="topic-card">
        <h3>45 minutes</h3>
        <p>Family visits are free and last about 45 minutes.</p>
      </article>
      <article class="topic-card">
        <h3>Who should come</h3>
        <p>Bring one or more children along with one or more caregivers.</p>
      </article>
      <article class="topic-card">
        <h3>Where to go</h3>
        <p>The Number Garden is at {studioAddress} in Portland.</p>
      </article>
      <article class="topic-card">
        <h3>What happens</h3>
        <p>You will see the space, meet Paul, and get a feel for how learning works here.</p>
      </article>
      <article class="topic-card">
        <h3>What we discuss</h3>
        <p>
          We talk through your child&apos;s needs, possible rhythm, schedule, cost,
          and access options before any enrollment decision.
        </p>
      </article>
    </div>
    <p class="supporting-copy">
      During your visit, you can expect an introduction to the studio, a short
      mathematical invitation, and a conversation about how The Number Garden
      can best serve your family&apos;s needs.
    </p>
    <p class="supporting-copy">
      Family visits are with Paul, founder of The Number Garden. He will meet
      with you directly, learn about your child, and help you decide whether
      the studio feels like the right fit.
    </p>
    <p class="supporting-copy">
      We are building a mix of family-paid, reduced-rate, and
      community-supported participation so more children can access serious,
      joyful mathematics.
    </p>
  </section>

  <section class="panel panel-accent contact-panel">
    <div class="section-heading">
      <p class="eyebrow">Ready?</p>
      <h2>Choose a time that works for your family.</h2>
    </div>
    <p class="contact-copy">
      Once you are ready, book your visit right here. If the popup does not
      open well on your device, you can use the direct booking link instead.
    </p>
    <div class="actions booking-actions">
      <a
        class="contact-link"
        href={visitBookingUrl}
        data-calendly-popup="family-visit"
      >
        Book a family visit
      </a>
      <p class="booking-direct-link">
        <a
          href={visitBookingUrl}
          target="_blank"
          rel="noreferrer"
          data-ga-event="booking_link_click"
          data-ga-label="Family Visit direct Calendly link"
        >
          Open booking in a new tab
        </a>
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .booking-actions {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.55rem;
  }

  .booking-direct-link {
    margin: 0;
    color: var(--muted);
    font-weight: 700;
  }
</style>

<script
  define:vars={{
    bookingUrl: siteConfig.familyVisitBookingUrl,
    calendlyWidgetScriptUrl: siteConfig.calendlyWidgetScriptUrl,
  }}
>
  const trackedCalendlyBookings = new Set();
  let calendlyWidgetPromise;
  const calendlyEventNames = {
    "calendly.date_and_time_selected": "calendly_date_and_time_selected",
    "calendly.event_scheduled": "calendly_event_scheduled",
  };

  const isCalendlyEvent = (event) =>
    event.origin === "https://calendly.com" &&
    typeof event.data?.event === "string" &&
    event.data.event.startsWith("calendly.");

  window.addEventListener("message", (event) => {
    if (!isCalendlyEvent(event)) {
      return;
    }

    const calendlyEventName = event.data.event;
    const calendlyPayload = event.data.payload || {};
    const calendlyParams = {
      event_label: "Family visit Calendly",
      calendly_event: calendlyEventName,
      calendly_event_uri: calendlyPayload.event?.uri,
      calendly_invitee_uri: calendlyPayload.invitee?.uri,
    };
    const mappedEventName = calendlyEventNames[calendlyEventName];

    if (mappedEventName) {
      window.ngTrackEvent?.(mappedEventName, calendlyParams);
    }

    if (calendlyEventName !== "calendly.event_scheduled") {
      return;
    }

    const bookingKey = calendlyPayload.event?.uri || calendlyPayload.invitee?.uri;

    if (bookingKey && trackedCalendlyBookings.has(bookingKey)) {
      return;
    }

    if (bookingKey) {
      trackedCalendlyBookings.add(bookingKey);
    }

    window.ngTrackEvent?.("calendly_booking_message_received", {
      event_label: "Family visit Calendly booking message",
      calendly_event: calendlyEventName,
      calendly_event_uri: calendlyPayload.event?.uri,
      calendly_invitee_uri: calendlyPayload.invitee?.uri,
    });
  });

  const getCalendlyWidget = () => {
    if (window.Calendly && typeof window.Calendly.initPopupWidget === "function") {
      return Promise.resolve(window.Calendly);
    }

    if (calendlyWidgetPromise) {
      return calendlyWidgetPromise;
    }

    calendlyWidgetPromise = new Promise((resolve, reject) => {
      const existingScript =
        document.querySelector("[data-calendly-widget-script]") ||
        document.querySelector(`script[src="${calendlyWidgetScriptUrl}"]`);
      const script = existingScript || document.createElement("script");
      const timeout = window.setTimeout(() => {
        reject(new Error("Calendly widget timed out."));
      }, 5000);

      const finish = () => {
        if (window.Calendly && typeof window.Calendly.initPopupWidget === "function") {
          window.clearTimeout(timeout);
          resolve(window.Calendly);
          return;
        }

        window.clearTimeout(timeout);
        reject(new Error("Calendly widget did not initialize."));
      };

      const fail = () => {
        window.clearTimeout(timeout);
        reject(new Error("Calendly widget failed to load."));
      };

      script.addEventListener("load", finish, { once: true });
      script.addEventListener("error", fail, { once: true });

      if (!existingScript) {
        script.src = calendlyWidgetScriptUrl;
        script.type = "text/javascript";
        script.async = true;
        script.dataset.calendlyWidgetScript = "";
        document.head.append(script);
      }
    });

    return calendlyWidgetPromise;
  };

  document.addEventListener("DOMContentLoaded", () => {
    document
      .querySelectorAll('[data-calendly-popup="family-visit"]')
      .forEach((trigger) => {
        trigger.addEventListener("click", (event) => {
          event.preventDefault();

          if (!trigger.hasAttribute("data-ga-event")) {
            window.ngTrackEvent?.("book_visit_click", {
              event_label: trigger.textContent.trim(),
            });
          }

          getCalendlyWidget()
            .then((Calendly) => {
              Calendly.initPopupWidget({ url: bookingUrl });
              window.ngTrackEvent?.("calendly_popup_open", {
                event_label: "Family visit Calendly popup",
              });
            })
            .catch(() => {
              calendlyWidgetPromise = undefined;
              window.location.href = bookingUrl;
            });
        });
      });
  });
</script>
