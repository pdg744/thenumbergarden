---
import BaseLayout from "../layouts/BaseLayout.astro";

const interestEmail = "experiential.education.pdx@gmail.com";
---

<BaseLayout
  title="Contact"
  description="Get in touch with The Number Garden in Portland and join the early interest list."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Contact</p>
      <h1>Say hello.</h1>
      <p class="lede">
        The Number Garden is taking root in the Hollywood neighborhood of
        Portland, at 4152 NE Sandy Blvd. If you would like to hear about
        openings, early programs, or upcoming conversations, reach out and
        introduce yourself.
      </p>
      <div class="actions">
        <a
          class="button button-primary"
          href={`mailto:${interestEmail}?subject=The%20Number%20Garden%20interest`}
        >
          Email the studio
        </a>
      </div>
    </div>

    <aside class="hero-card" aria-label="Contact prompts">
      <p class="card-label">Where to find us</p>
      <ul>
        <li>Hollywood neighborhood, Portland</li>
        <li>4152 NE Sandy Blvd</li>
        <li>Families, educators, and collaborators welcome</li>
        <li>Early interest is encouraged</li>
      </ul>
    </aside>
  </section>

  <section class="panel panel-light contact-panel">
    <div class="section-heading">
      <p class="eyebrow">Contact</p>
      <h2>Early interest is welcome.</h2>
    </div>
    <p class="contact-copy">
      A short note is enough. You can say who you are, what drew you here, and
      what you would love to hear about as the project develops.
    </p>
    <a class="contact-link" href={`mailto:${interestEmail}`}>
      {interestEmail}
    </a>
  </section>
</BaseLayout>
