---
import BaseLayout from "../layouts/BaseLayout.astro";
import { siteConfig } from "../config/site";

const interestEmail = siteConfig.contactEmail;
const scholarshipsEmail = siteConfig.scholarshipsEmail;
const transportationEmail = siteConfig.transportationEmail;
---

<BaseLayout
  title="Contact"
  description="Contact The Number Garden in Portland with questions about math tutoring, enrichment, access options, or booking a free family visit."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Contact</p>
      <h1>Questions before you book?</h1>
      <p class="lede">
        If you want to ask something before scheduling, email is welcome. If you
        already think The Number Garden might be a fit, the main next step is to
        book a family visit.
      </p>
      <div class="actions">
        <a
          class="button button-primary"
          href="/family-visit/"
          data-ga-event="book_visit_click"
          data-ga-label="Contact hero Book a family visit"
        >
          Book a family visit
        </a>
        <a
          class="button button-secondary"
          href={`mailto:${interestEmail}`}
          data-ga-event="email_click"
          data-ga-label="Contact hero email"
        >
          Email Paul
        </a>
      </div>
    </div>

    <aside class="hero-card" aria-label="Contact prompts">
      <p class="card-label">Best next step</p>
      <ul>
        <li>Book a family visit if you are ready to explore fit</li>
        <li>Email if you have a quick question first</li>
        <li>Family visits are free and last about 45 minutes</li>
        <li>The studio is at {siteConfig.address.street}</li>
      </ul>
    </aside>
  </section>

  <section class="panel panel-light">
    <div class="section-heading">
      <p class="eyebrow">Direct Contact</p>
      <h2>Email is welcome.</h2>
    </div>
    <p class="supporting-copy">
      Reach out directly if you want to ask about age range, schedule,
      ongoing support, reduced-rate options, transportation, or whether a family
      visit makes sense for your child.
    </p>
    <a
      class="contact-link"
      href={`mailto:${interestEmail}`}
      data-ga-event="email_click"
      data-ga-label="Contact direct email"
    >
      {interestEmail}
    </a>
    <p class="supporting-copy">
      For financial support, email{" "}
      <a href={`mailto:${scholarshipsEmail}`}>{scholarshipsEmail}</a>. For
      transportation support, email{" "}
      <a href={`mailto:${transportationEmail}`}>{transportationEmail}</a>.
    </p>
  </section>
</BaseLayout>
