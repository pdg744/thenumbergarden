---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout
  title="Logo Lab"
  description="A parameterized studio for rebuilding The Number Garden logo mark from pentagonal-number circle rings."
>
  <section class="logo-lab panel panel-light">
    <div class="lab-copy">
      <p class="eyebrow">Logo Lab</p>
      <h1>Pentagonal circle mark generator</h1>
      <p>
        A reconstruction of the Number Garden mark from overlapping circles
        placed along concentric pentagonal-number rings.
      </p>
    </div>

    <div class="lab-workbench" data-logo-lab>
      <div class="preview-panel" aria-label="Generated logo preview">
        <div class="preview-surface" data-preview></div>
        <div class="output-actions">
          <button class="lab-button" type="button" data-copy-svg>Copy SVG</button>
          <button class="lab-button lab-button-primary" type="button" data-download-svg>
            Download SVG
          </button>
        </div>
      </div>

      <form class="control-panel" aria-label="Logo generator controls">
        <fieldset>
          <legend>Geometry</legend>
          <label>
            <span>Rings <output data-output-for="rings">4</output></span>
            <input name="rings" type="range" min="1" max="8" step="1" value="4" />
          </label>
          <label>
            <span>Pale rings <output data-output-for="innerRings">2</output></span>
            <input name="innerRings" type="range" min="1" max="8" step="1" value="2" />
          </label>
          <label>
            <span>First ring radius <output data-output-for="firstRadius">18</output></span>
            <input name="firstRadius" type="range" min="4" max="36" step="0.1" value="18" />
          </label>
          <label>
            <span>Ring spacing <output data-output-for="spacing">14.2</output></span>
            <input name="spacing" type="range" min="6" max="30" step="0.1" value="14.2" />
          </label>
          <label>
            <span>Circle radius <output data-output-for="circleRadius">13.1</output></span>
            <input name="circleRadius" type="range" min="3" max="24" step="0.1" value="13.1" />
          </label>
          <label>
            <span>Rotation <output data-output-for="rotation">-54</output></span>
            <input name="rotation" type="range" min="-180" max="180" step="1" value="-54" />
          </label>
          <label>
            <span>Ring twist <output data-output-for="ringTwist">-36</output></span>
            <input name="ringTwist" type="range" min="-72" max="72" step="1" value="-36" />
          </label>
          <label>
            <span>Canvas padding <output data-output-for="padding">24</output></span>
            <input name="padding" type="range" min="0" max="80" step="1" value="24" />
          </label>
        </fieldset>

        <fieldset>
          <legend>Drawing</legend>
          <label>
            <span>Guide opacity <output data-output-for="guideOpacity">0.9</output></span>
            <input name="guideOpacity" type="range" min="0" max="1" step="0.05" value="0.9" />
          </label>
          <label>
            <span>Guide stroke <output data-output-for="guideStroke">1.5</output></span>
            <input name="guideStroke" type="range" min="0.2" max="4" step="0.1" value="1.5" />
          </label>
          <label class="toggle-row">
            <span>Show pentagons</span>
            <input name="showGuides" type="checkbox" checked />
          </label>
          <label class="toggle-row">
            <span>Transparent background</span>
            <input name="transparent" type="checkbox" checked />
          </label>
        </fieldset>

        <fieldset>
          <legend>Palette</legend>
          <label class="color-row">
            <span>Center</span>
            <input name="centerColor" type="color" value="#36543b" />
          </label>
          <label class="color-row">
            <span>Inner ring</span>
            <input name="innerColor" type="color" value="#dbe8d0" />
          </label>
          <label class="color-row">
            <span>Middle ring</span>
            <input name="middleColor" type="color" value="#6c8a53" />
          </label>
          <label class="color-row">
            <span>Outer ring</span>
            <input name="outerColor" type="color" value="#36543b" />
          </label>
          <label class="color-row">
            <span>Guide</span>
            <input name="guideColor" type="color" value="#dbe8d0" />
          </label>
          <label class="color-row">
            <span>Background</span>
            <input name="backgroundColor" type="color" value="#faf6ec" />
          </label>
        </fieldset>
      </form>
    </div>
  </section>
</BaseLayout>

<script>
  import { buildPentagonalCircleMarkSvg } from "../lib/logo/pentagonalCircleMark.js";

  const lab = document.querySelector("[data-logo-lab]");
  const form = lab?.querySelector("form");
  const preview = lab?.querySelector("[data-preview]");
  const copyButton = lab?.querySelector("[data-copy-svg]");
  const downloadButton = lab?.querySelector("[data-download-svg]");

  const numberFormatter = new Intl.NumberFormat("en-US", {
    maximumFractionDigits: 2,
  });

  let latestSvg = "";

  const readSettings = () => {
    const data = new FormData(form);
    const rings = Number(data.get("rings"));

    return {
      rings,
      innerRings: Math.min(Number(data.get("innerRings")), rings),
      firstRadius: Number(data.get("firstRadius")),
      spacing: Number(data.get("spacing")),
      circleRadius: Number(data.get("circleRadius")),
      rotation: Number(data.get("rotation")),
      ringTwist: Number(data.get("ringTwist")),
      padding: Number(data.get("padding")),
      guideOpacity: Number(data.get("guideOpacity")),
      guideStroke: Number(data.get("guideStroke")),
      showGuides: data.get("showGuides") === "on",
      transparent: data.get("transparent") === "on",
      centerColor: String(data.get("centerColor")),
      innerColor: String(data.get("innerColor")),
      middleColor: String(data.get("middleColor")),
      outerColor: String(data.get("outerColor")),
      guideColor: String(data.get("guideColor")),
      backgroundColor: String(data.get("backgroundColor")),
    };
  };

  const updateOutputs = (settings) => {
    for (const [name, value] of Object.entries(settings)) {
      const output = lab?.querySelector(`[data-output-for="${name}"]`);

      if (output) {
        output.textContent = typeof value === "number" ? numberFormatter.format(value) : String(value);
      }
    }
  };

  const render = () => {
    const settings = readSettings();
    latestSvg = buildPentagonalCircleMarkSvg(settings);
    updateOutputs(settings);

    if (preview) {
      preview.innerHTML = latestSvg;
    }
  };

  form?.addEventListener("input", render);
  form?.addEventListener("change", render);

  copyButton?.addEventListener("click", async () => {
    await navigator.clipboard.writeText(latestSvg);
    copyButton.textContent = "Copied";
    window.setTimeout(() => {
      copyButton.textContent = "Copy SVG";
    }, 1200);
  });

  downloadButton?.addEventListener("click", () => {
    const blob = new Blob([latestSvg], { type: "image/svg+xml" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement("a");
    link.href = url;
    link.download = "number-garden-logo-mark.svg";
    link.click();
    URL.revokeObjectURL(url);
  });

  render();
</script>

<style>
  .logo-lab {
    display: grid;
    gap: 1.5rem;
  }

  .lab-copy {
    display: grid;
    gap: 0.8rem;
    max-width: 48rem;
  }

  .lab-copy h1 {
    max-width: 14ch;
    font-size: clamp(2.5rem, 5vw, 4.6rem);
    line-height: 0.96;
  }

  .lab-copy p:last-child {
    margin: 0;
    color: var(--muted);
  }

  .lab-workbench {
    display: grid;
    grid-template-columns: minmax(320px, 1fr) minmax(280px, 380px);
    gap: 1.2rem;
    align-items: start;
  }

  .preview-panel,
  .control-panel {
    border: 1px solid rgba(54, 84, 59, 0.14);
    border-radius: 22px;
    background: rgba(255, 250, 242, 0.72);
  }

  .preview-panel {
    display: grid;
    gap: 1rem;
    padding: 1rem;
  }

  .preview-surface {
    display: grid;
    place-items: center;
    min-height: 560px;
    border-radius: 16px;
    background:
      linear-gradient(45deg, rgba(54, 84, 59, 0.06) 25%, transparent 25%),
      linear-gradient(-45deg, rgba(54, 84, 59, 0.06) 25%, transparent 25%),
      linear-gradient(45deg, transparent 75%, rgba(54, 84, 59, 0.06) 75%),
      linear-gradient(-45deg, transparent 75%, rgba(54, 84, 59, 0.06) 75%),
      var(--cream-bright);
    background-position:
      0 0,
      0 10px,
      10px -10px,
      -10px 0;
    background-size: 20px 20px;
    box-shadow: inset 0 0 0 1px rgba(54, 84, 59, 0.1);
  }

  .preview-surface :global(svg) {
    display: block;
    width: min(86%, 520px);
    height: auto;
    filter: drop-shadow(0 26px 36px rgba(31, 42, 31, 0.16));
  }

  .output-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .lab-button {
    min-height: 2.8rem;
    padding: 0 1rem;
    border: 0;
    border-radius: 999px;
    background: rgba(54, 84, 59, 0.09);
    color: var(--moss);
    font: inherit;
    font-weight: 800;
    cursor: pointer;
  }

  .lab-button-primary {
    background: var(--moss);
    color: var(--paper-inverse-strong);
  }

  .control-panel {
    display: grid;
    gap: 1rem;
    padding: 1rem;
  }

  fieldset {
    display: grid;
    gap: 0.95rem;
    margin: 0;
    padding: 0 0 1rem;
    border: 0;
    border-bottom: 1px solid rgba(54, 84, 59, 0.12);
  }

  fieldset:last-child {
    padding-bottom: 0;
    border-bottom: 0;
  }

  legend {
    margin-bottom: 0.8rem;
    color: var(--ink);
    font-weight: 900;
  }

  label {
    display: grid;
    gap: 0.45rem;
    color: var(--muted);
    font-size: 0.94rem;
    font-weight: 800;
  }

  label > span {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
  }

  output {
    color: var(--moss);
  }

  input[type="range"] {
    width: 100%;
    accent-color: var(--moss);
  }

  .toggle-row,
  .color-row {
    grid-template-columns: minmax(0, 1fr) auto;
    align-items: center;
  }

  .toggle-row input {
    width: 1.15rem;
    height: 1.15rem;
    accent-color: var(--moss);
  }

  .color-row input {
    width: 3rem;
    height: 2.1rem;
    padding: 0.12rem;
    border: 1px solid rgba(54, 84, 59, 0.22);
    border-radius: 10px;
    background: var(--cream-bright);
  }

  @media (max-width: 920px) {
    .lab-workbench {
      grid-template-columns: 1fr;
    }

    .preview-surface {
      min-height: 420px;
    }
  }

  @media (max-width: 560px) {
    .preview-panel,
    .control-panel {
      border-radius: 18px;
    }

    .preview-surface {
      min-height: 320px;
    }

    .output-actions {
      display: grid;
    }
  }
</style>
