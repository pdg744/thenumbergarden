---
import BaseLayout from "../layouts/BaseLayout.astro";
import { mailtoHref, siteConfig } from "../config/site";

const partnerEmailHref = mailtoHref(
  siteConfig.contactEmail,
  "School, PTA, or community conversation"
);
---

<BaseLayout
  title="Portland Math Studio for Tutoring & Enrichment"
  description="The Number Garden is a Portland math studio offering warm, inquiry-driven tutoring, enrichment, and small-group math experiences for children and families."
>
  <section class="hero">
    <div class="hero-copy">
      <h1>Joyful mathematics for curious minds in Portland.</h1>
      <p class="lede">
        The Number Garden is a warm, inquiry-driven math studio in Portland for
        families who want mathematics to feel alive: playful, rigorous,
        beautiful, and full of genuine discovery.
      </p>
      <div class="actions">
        <a
          class="button button-primary"
          href="/family-visit/"
          data-ga-event="book_visit_click"
          data-ga-label="Home hero Book a family visit"
        >
          Book a family visit
        </a>
        <a class="button button-secondary" href="/portland-math-camp/">
          August math camp
        </a>
      </div>
    </div>

    <aside class="hero-card" aria-label="What grows at The Number Garden">
      <p class="card-label">What grows here</p>
      <ul>
        <li>Early family math rooted in play, pattern, and wonder</li>
        <li>Rich problems worth lingering over</li>
        <li>Challenge without hurry or coercion</li>
        <li>Support for confidence, fluency, and deep thinking</li>
      </ul>
    </aside>
  </section>

  <section class="panel panel-light">
    <div class="section-heading">
      <h2>Who this is for</h2>
    </div>
    <p class="supporting-copy">
      Families come to The Number Garden for different reasons. Some want a
      joyful early start in mathematics. Some are looking for richer challenge.
      Some want a warmer path back into confidence and fluency.
    </p>
    <div class="card-grid" aria-label="Who The Number Garden is for">
      <article class="topic-card">
        <h3>Early family math</h3>
        <p>
          For families who want young children to grow up with mathematics as
          part of life: playful, curious, social, and full of wonder.
        </p>
      </article>
      <article class="topic-card">
        <h3>Deeper challenge</h3>
        <p>
          For students who are ready for richer problems, deeper challenge, and
          more real mathematical thinking than school usually offers.
        </p>
      </article>
      <article class="topic-card">
        <h3>Rebuilding confidence</h3>
        <p>
          For students who need steadier support, stronger foundations, and a
          warmer path back into mathematical confidence and fluency.
        </p>
      </article>
    </div>
  </section>

  <section class="panel panel-light">
    <div class="section-heading">
      <p class="eyebrow">What Happens Next</p>
      <h2>A simple first step.</h2>
    </div>
    <p class="supporting-copy">
      Some families begin by registering for August math camp. Others start
      with a family visit to talk through tutoring, enrichment, confidence,
      challenge, or fit. Either way, the goal is a clear, low-pressure first
      step.
    </p>
    <div class="card-grid" aria-label="What happens next">
      <article class="topic-card">
        <h3>Register for camp</h3>
        <p>
          August math camp is open for ages 8-10 and 11-15, with playful,
          rigorous math at the studio.
        </p>
      </article>
      <article class="topic-card">
        <h3>Explore tutoring</h3>
        <p>
          For ongoing support, enrichment, challenge, or confidence-building,
          start with the tutoring page.
        </p>
      </article>
      <article class="topic-card">
        <h3>Book a family visit</h3>
        <p>
          If you want to meet first, book a free visit to see the space and
          talk about your child.
        </p>
      </article>
    </div>
    <div class="actions">
      <a
        class="button button-primary button-large"
        href="/portland-math-camp/"
        data-ga-event="camp_page_click"
        data-ga-label="Home next step August math camp"
      >
        August math camp
      </a>
      <a class="button button-secondary button-large" href="/portland-math-tutor/">
        Math tutoring
      </a>
      <a
        class="button button-secondary button-large"
        href="/family-visit/"
        data-ga-event="book_visit_click"
        data-ga-label="Home next step Book a family visit"
      >
        Book a family visit
      </a>
    </div>
  </section>

  <section class="panel panel-accent">
    <div class="section-heading">
      <p class="eyebrow">Schools, PTAs, and Community Partners</p>
      <h2>Interested in joyful math for your community?</h2>
    </div>
    <p class="supporting-copy">
      The Number Garden is beginning conversations with PTAs, schools, and
      community organizations interested in warm, rigorous math experiences
      for children and families.
    </p>
    <p class="supporting-copy">
      If you are imagining a family math night, a small-group enrichment
      experience, or a partnership that helps more children meet mathematics
      with curiosity and confidence, email Paul to start a conversation.
    </p>
    <div class="actions">
      <a
        class="button button-primary"
        href={partnerEmailHref}
        data-ga-event="email_click"
        data-ga-label="Home schools PTAs community email"
      >
        Start a conversation
      </a>
    </div>
  </section>

  <section class="panel panel-light contact-panel">
    <div class="section-heading">
      <p class="eyebrow">Stay in Touch</p>
      <h2>Not ready to book a visit yet?</h2>
    </div>
    <p class="contact-copy">
      Join the email list to stay informed.
    </p>
    <form
      action={siteConfig.newsletterActionUrl}
      method="post"
      class="signup-form"
      data-ga-event="newsletter_signup_submit"
      data-ga-label="Home Buttondown signup"
    >
      <input type="hidden" name="embed" value="1" />
      <input type="hidden" name="tag" value="general-newsletter" />
      <input type="hidden" name="tag" value="source-homepage" />
      <input type="hidden" name="metadata__signup_intent" value="general-newsletter" />
      <input type="hidden" name="metadata__source_page" value="home" />
      <div class="signup-form-field">
        <label for="bd-email">Email address</label>
        <input type="email" name="email" id="bd-email" required />
      </div>
      <input type="submit" value="Join the list" />
    </form>
    <p class="signup-note">
      <a href={siteConfig.newsletterReferralUrl} target="_blank" rel="noreferrer">
        Powered by Buttondown
      </a>
    </p>
  </section>
</BaseLayout>
