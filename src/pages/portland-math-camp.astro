---
import BaseLayout from "../layouts/BaseLayout.astro";
import { mailtoHref, siteConfig } from "../config/site";

const emailHref = mailtoHref(siteConfig.contactEmail, siteConfig.camp.emailSubject);
const campDescription = `The Number Garden is launching a small August math camp in Portland from ${siteConfig.camp.dateRange}, with playful, rigorous math for ages 8-10 and 11-15.`;
---

<BaseLayout
  title="Portland Math Camp"
  description={campDescription}
>
  <section class="hero camp-hero">
    <div class="hero-copy">
      <p class="eyebrow">{siteConfig.camp.dateRange}</p>
      <h1>A small August math camp in Portland.</h1>
      <p class="lede">
        The Number Garden is launching a week of playful, rigorous mathematics
        for children who like puzzles, games, patterns, strategy, and beautiful
        questions worth lingering over.
      </p>
      <div class="actions">
        <a
          class="button button-primary"
          href="#camp-registration"
          data-ga-event="camp_registration_click"
          data-ga-label="Camp hero registration"
        >
          Register for camp
        </a>
        <a
          class="button button-secondary"
          href={emailHref}
          data-ga-event="email_click"
          data-ga-label="Camp hero email"
        >
          Email a camp question
        </a>
      </div>
    </div>

    <aside class="hero-card" aria-label="August math camp schedule">
      <p class="card-label">Camp Week</p>
      <ul>
        <li>{siteConfig.camp.weekdayRange}</li>
        <li>{siteConfig.camp.youngerGroup}</li>
        <li>{siteConfig.camp.olderGroup}</li>
        <li>At The Number Garden studio in Portland</li>
      </ul>
    </aside>
  </section>

  <section class="panel panel-light">
    <div class="section-heading">
      <p class="eyebrow">What Camp Feels Like</p>
      <h2>Joyful math with real depth.</h2>
    </div>
    <p class="supporting-copy">
      This is not a worksheet camp or a race through school topics. Campers
      will spend the week exploring rich mathematical invitations: puzzles,
      games, patterns, strategy, visual structure, and problems with room for
      many kinds of thinkers.
    </p>
    <div class="card-grid" aria-label="What happens at August math camp">
      <article class="topic-card">
        <h3>Puzzles and games</h3>
        <p>
          Campers work with playful problems that invite strategy, persistence,
          and surprise.
        </p>
      </article>
      <article class="topic-card">
        <h3>Patterns and structure</h3>
        <p>
          We look for what changes, what stays the same, and what might be true
          beneath the surface.
        </p>
      </article>
      <article class="topic-card">
        <h3>Conversation and conjecture</h3>
        <p>
          Children learn to notice, explain, test ideas, revise, and listen to
          one another.
        </p>
      </article>
    </div>
  </section>

  <section class="panel panel-accent">
    <div class="section-heading">
      <p class="eyebrow">Groups</p>
      <h2>Two age bands, one week.</h2>
    </div>
    <div class="card-grid" aria-label="August math camp groups">
      <article class="topic-card">
        <h3>Ages 8-10</h3>
        <p>
          A morning group from 9-11am, built around playful entry points,
          mathematical games, patterns, and shared discovery.
        </p>
      </article>
      <article class="topic-card">
        <h3>Ages 11-15</h3>
        <p>
          An afternoon group from 1-3:30pm, with deeper challenges, richer
          strategy, and more room to pursue ideas in depth.
        </p>
      </article>
      <article class="topic-card">
        <h3>Small by design</h3>
        <p>
          The camp will be intentionally small so the work can feel personal,
          social, and responsive to the children in the room.
        </p>
      </article>
    </div>
  </section>

  <section class="panel panel-light">
    <div class="section-heading">
      <p class="eyebrow">Who It Is For</p>
      <h2>For many relationships to math.</h2>
    </div>
    <p class="supporting-copy">
      This camp can be a fit for children who already love puzzles and want
      more challenge. It can also be a fit for children who need a warmer, more
      playful experience of mathematics than school has offered them.
    </p>
    <p class="supporting-copy">
      The common thread is curiosity: a willingness to try, notice, wonder,
      explain, and stay with an interesting problem.
    </p>
  </section>

  <section class="panel panel-accent" id="camp-registration">
    <div class="section-heading">
      <p class="eyebrow">Registration</p>
      <h2>Choose the right August camp group.</h2>
    </div>
    <p class="supporting-copy">
      Registration is handled through Stripe. Choose the group that matches
      your child's age for the week of camp.
    </p>
    <div class="card-grid camp-registration-grid" aria-label="August math camp registration options">
      <article class="topic-card registration-card">
        <h3>Ages 8-10</h3>
        <p>Morning camp from 9-11am, Monday-Friday, August 10-14.</p>
        <a
          class="button button-primary"
          href={siteConfig.camp.youngerRegistrationUrl}
          target="_blank"
          rel="noreferrer"
          data-ga-event="camp_registration_click"
          data-ga-label="Ages 8-10 Stripe registration"
        >
          Register ages 8-10
        </a>
      </article>
      <article class="topic-card registration-card">
        <h3>Ages 11-15</h3>
        <p>Afternoon camp from 1-3:30pm, Monday-Friday, August 10-14.</p>
        <a
          class="button button-primary"
          href={siteConfig.camp.olderRegistrationUrl}
          target="_blank"
          rel="noreferrer"
          data-ga-event="camp_registration_click"
          data-ga-label="Ages 11-15 Stripe registration"
        >
          Register ages 11-15
        </a>
      </article>
      <article class="topic-card registration-card">
        <h3>Questions first?</h3>
        <p>Email with age, fit, schedule, or payment questions before registering.</p>
        <a
          class="button button-secondary"
          href={emailHref}
          data-ga-event="email_click"
          data-ga-label="Camp registration email"
        >
          Email a camp question
        </a>
      </article>
    </div>
  </section>

  <section class="panel panel-light contact-panel" id="camp-interest">
    <div class="section-heading">
      <p class="eyebrow">August Camp Interest</p>
      <h2>Not ready to register?</h2>
    </div>
    <p class="contact-copy">
      Join the list for camp updates, or email directly with age, availability,
      or fit questions.
    </p>
    <form
      action={siteConfig.newsletterActionUrl}
      method="post"
      class="signup-form"
      data-ga-event="camp_interest_signup_submit"
      data-ga-label="August math camp Buttondown signup"
    >
      <input type="hidden" name="embed" value="1" />
      <input type="hidden" name="tag" value="august-math-camp-interest" />
      <input type="hidden" name="tag" value="source-camp-page" />
      <input type="hidden" name="metadata__signup_intent" value="august-math-camp" />
      <input type="hidden" name="metadata__source_page" value="portland-math-camp" />
      <input type="hidden" name="metadata__offer" value="August math camp" />
      <div class="signup-form-field">
        <label for="camp-email">Email address</label>
        <input type="email" name="email" id="camp-email" required />
      </div>
      <input type="submit" value="Join the camp list" />
    </form>
    <div class="inline-links camp-links">
      <a
        class="card-link"
        href={emailHref}
        data-ga-event="email_click"
        data-ga-label="Camp interest email"
      >
        Email about camp
      </a>
      <a class="card-link" href="/family-visit/">
        Visit the studio first
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .camp-hero .hero-card li {
    font-weight: 700;
  }

  .camp-links {
    justify-content: center;
  }

  .registration-card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .registration-card .button {
    align-self: flex-start;
    margin-top: auto;
  }
</style>
