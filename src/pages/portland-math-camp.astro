---
import BaseLayout from "../layouts/BaseLayout.astro";
import { mailtoHref, siteConfig } from "../config/site";

const emailHref = mailtoHref(siteConfig.contactEmail, siteConfig.camp.emailSubject);
const campDescription = `A small August math camp in Portland from ${siteConfig.camp.dateRange}, with playful, rigorous math for ages 8-10 and 11-15.`;
---

<BaseLayout
  title="Portland Math Camp"
  description={campDescription}
>
  <section class="hero camp-hero">
    <div class="hero-copy">
      <p class="eyebrow">August 10-14, 2026</p>
      <h1>August Math Camp</h1>
      <p class="lede">
        A small Portland camp for kids who like puzzles, games, patterns,
        strategy, and beautiful questions worth lingering over.
      </p>
    </div>

    <div class="hero-card camp-session-stack" aria-label="August math camp registration options">
      <p class="card-label">Registration</p>
      <article class="camp-session-card">
        <div>
          <h2>Ages 8-10</h2>
          <p>9-11am, Monday-Friday</p>
        </div>
        <a
          class="button button-primary"
          href={siteConfig.camp.youngerRegistrationUrl}
          target="_blank"
          rel="noreferrer"
          data-ga-event="camp_registration_click"
          data-ga-label="Ages 8-10 Stripe registration"
        >
          Register
        </a>
      </article>
      <article class="camp-session-card">
        <div>
          <h2>Ages 11-15</h2>
          <p>1-3:30pm, Monday-Friday</p>
        </div>
        <a
          class="button button-primary"
          href={siteConfig.camp.olderRegistrationUrl}
          target="_blank"
          rel="noreferrer"
          data-ga-event="camp_registration_click"
          data-ga-label="Ages 11-15 Stripe registration"
        >
          Register
        </a>
      </article>
      <p class="camp-location-note">At The Number Garden studio in Portland.</p>
    </div>
  </section>

  <section class="panel panel-light">
    <div class="section-heading">
      <p class="eyebrow">What Camp Is Like</p>
      <h2>Joyful math with real depth.</h2>
    </div>
    <p class="supporting-copy">
      This is not a worksheet camp or a race through school topics. Campers
      will spend the week exploring rich mathematical invitations: puzzles,
      games, patterns, strategy, visual structure, and problems with room for
      many kinds of thinkers.
    </p>
    <div class="card-grid" aria-label="What happens at August math camp">
      <article class="topic-card">
        <h3>Puzzles and games</h3>
        <p>
          Campers work with playful problems that invite strategy, persistence,
          and surprise.
        </p>
      </article>
      <article class="topic-card">
        <h3>Patterns and structure</h3>
        <p>
          We look for what changes, what stays the same, and what might be true
          beneath the surface.
        </p>
      </article>
      <article class="topic-card">
        <h3>Conversation and conjecture</h3>
        <p>
          Children learn to notice, explain, test ideas, revise, and listen to
          one another.
        </p>
      </article>
    </div>
  </section>

  <section class="panel panel-accent">
    <div class="section-heading">
      <p class="eyebrow">Who It Is For</p>
      <h2>For many relationships to math.</h2>
    </div>
    <p class="supporting-copy">
      This camp can be a fit for children who already love puzzles and want
      more challenge. It can also be a fit for children who need a warmer, more
      playful experience of mathematics than school has offered them.
    </p>
    <p class="supporting-copy">
      The common thread is curiosity: a willingness to try, notice, wonder,
      explain, and stay with an interesting problem.
    </p>
    <div class="actions section-actions">
      <a
        class="button button-primary"
        href={siteConfig.camp.youngerRegistrationUrl}
        target="_blank"
        rel="noreferrer"
        data-ga-event="camp_registration_click"
        data-ga-label="Who it is for ages 8-10 Stripe registration"
      >
        Register ages 8-10
      </a>
      <a
        class="button button-primary"
        href={siteConfig.camp.olderRegistrationUrl}
        target="_blank"
        rel="noreferrer"
        data-ga-event="camp_registration_click"
        data-ga-label="Who it is for ages 11-15 Stripe registration"
      >
        Register ages 11-15
      </a>
      <a
        class="button button-secondary"
        href={emailHref}
        data-ga-event="email_click"
        data-ga-label="Camp fit email"
      >
        Ask about fit
      </a>
    </div>
  </section>

  <section class="panel panel-light contact-panel" id="camp-interest">
    <div class="section-heading">
      <p class="eyebrow">August Camp Interest</p>
      <h2>Not ready to register?</h2>
    </div>
    <p class="contact-copy">
      Join the list for camp updates, or email directly with age, availability,
      or fit questions.
    </p>
    <form
      action={siteConfig.newsletterActionUrl}
      method="post"
      class="signup-form"
      data-ga-event="camp_interest_signup_submit"
      data-ga-label="August math camp Buttondown signup"
    >
      <input type="hidden" name="embed" value="1" />
      <input type="hidden" name="tag" value="august-math-camp-interest" />
      <input type="hidden" name="tag" value="source-camp-page" />
      <input type="hidden" name="metadata__signup_intent" value="august-math-camp" />
      <input type="hidden" name="metadata__source_page" value="portland-math-camp" />
      <input type="hidden" name="metadata__offer" value="August math camp" />
      <div class="signup-form-field">
        <label for="camp-email">Email address</label>
        <input type="email" name="email" id="camp-email" required />
      </div>
      <input type="submit" value="Join the camp list" />
    </form>
    <div class="inline-links camp-links">
      <a
        class="card-link"
        href={emailHref}
        data-ga-event="email_click"
        data-ga-label="Camp interest email"
      >
        Email about camp
      </a>
      <a class="card-link" href="/family-visit/">
        Visit the studio first
      </a>
    </div>
  </section>
</BaseLayout>

<style>
  .camp-hero h1 {
    max-width: 9ch;
  }

  .camp-hero .hero-copy {
    display: grid;
  }

  .camp-session-stack {
    display: grid;
    gap: 1rem;
  }

  .camp-session-card {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding: 1rem;
    border-radius: var(--radius-md);
    background: rgba(255, 250, 242, 0.14);
    box-shadow: inset 0 0 0 1px rgba(255, 250, 242, 0.18);
  }

  .camp-session-card h2 {
    font-size: clamp(1.55rem, 2vw, 2rem);
  }

  .camp-session-card .button-primary {
    background: var(--paper-inverse-strong);
    color: var(--moss);
  }

  .camp-session-card p,
  .camp-location-note {
    margin: 0.2rem 0 0;
    color: var(--paper-inverse);
  }

  .camp-location-note {
    font-weight: 700;
  }

  .section-actions {
    margin-top: 1.4rem;
  }

  .camp-links {
    justify-content: center;
  }

  @media (max-width: 720px) {
    .camp-hero .lede {
      order: 3;
    }

    .camp-hero .actions {
      order: 2;
      margin-top: 1.4rem;
    }
  }

  @media (max-width: 560px) {
    .camp-session-card {
      grid-template-columns: 1fr;
    }

    .camp-session-card .button {
      width: 100%;
    }
  }

</style>
