---
const destination = "https://maps.app.goo.gl/5X5HBHmZuPr2mLGt6";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="robots" content="noindex, follow" />
    <meta name="description" content="Open The Number Garden map." />
    <meta http-equiv="refresh" content={`0; url=${destination}`} />
    <link rel="canonical" href={destination} />
    <title>Map | The Number Garden</title>
    <script is:inline define:vars={{ destination }}>
      window.location.replace(destination);
    </script>
    <style>
      :root {
        color-scheme: light dark;
        font-family:
          ui-sans-serif,
          system-ui,
          -apple-system,
          BlinkMacSystemFont,
          "Segoe UI",
          sans-serif;
      }

      body {
        align-items: center;
        display: flex;
        justify-content: center;
        margin: 0;
        min-height: 100vh;
      }

      main {
        max-width: 34rem;
        padding: 2rem;
        text-align: center;
      }

      h1 {
        font-size: 1.25rem;
        font-weight: 650;
        margin: 0 0 0.75rem;
      }

      p {
        line-height: 1.5;
        margin: 0;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>Opening The Number Garden map</h1>
      <p>If you are not redirected automatically, <a href={destination}>open the map</a>.</p>
    </main>
  </body>
</html>
