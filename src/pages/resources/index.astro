---
import BaseLayout from "../../layouts/BaseLayout.astro";
import {
  getResourceDisplayTitle,
  getResourceFormat,
  resourceFilters,
  resourceImageByTitle,
  resourceSourceProfiles,
  resources,
} from "../../data/resources";

const audienceLabelById = Object.fromEntries(
  resourceFilters.map((filter) => [filter.id, filter.label]),
);
const resourceFormats = [...new Set(resources.map((resource) => getResourceFormat(resource.kind)))].sort(
  (left, right) => left.localeCompare(right),
);
---

<BaseLayout
  title="Resources"
  description="A growing library of joyful mathematics resources for families, self-study, teachers, schools, and curious people of all kinds."
>
  <section class="panel panel-light resources-panel">
    <div class="resources-intro">
      <div class="resources-intro-header">
        <h1>Resources</h1>
        <div class="resources-intro-controls">
          <button
            class="resources-filter-toggle"
            type="button"
            data-filter-toggle
            aria-expanded="false"
            aria-controls="resource-filter-panel"
            aria-label="Open filters"
          >
            <svg
              class="resources-filter-icon"
              viewBox="0 0 24 24"
              width="20"
              height="20"
              aria-hidden="true"
              focusable="false"
            >
              <path
                d="M4 7h16M7 12h10m-7 5h4"
                fill="none"
                stroke="currentColor"
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="1.8"
              ></path>
            </svg>
            <span>Filter</span>
          </button>
          <button class="resources-clear-button" type="button" data-clear-filters>
            Clear filters
          </button>
        </div>
      </div>
      <div class="resources-active-filters" data-active-filters>
        <p class="resources-active-summary" data-active-filter-summary></p>
      </div>

      <div class="resources-filter-panel" id="resource-filter-panel" data-filter-panel hidden>
        <div class="resources-filter-group">
          <p class="eyebrow">Audience</p>
          <div class="resources-filter-options">
            {
              resourceFilters.map((filter) => (
                <button
                  class="resource-filter-option"
                  type="button"
                  data-filter-group="audience"
                  data-filter-value={filter.id}
                  aria-label={`Show only ${filter.label.toLowerCase()} resources`}
                >
                  {filter.label}
                </button>
              ))
            }
          </div>
        </div>

        <div class="resources-filter-group">
          <p class="eyebrow">Format</p>
          <div class="resources-filter-options">
            {
              resourceFormats.map((format) => (
                <button
                  class="resource-filter-option"
                  type="button"
                  data-filter-group="format"
                  data-filter-value={format}
                  aria-label={`Filter by format: ${format}`}
                >
                  {format}
                </button>
              ))
            }
          </div>
        </div>
      </div>
    </div>

    <div class="resources-grid" data-resources-grid>
      {
        resources.map((resource) => {
          const displayTitle = getResourceDisplayTitle(resource);
          const image = resourceImageByTitle[resource.title];
          const format = getResourceFormat(resource.kind);
          const imageClass = [
            "resource-image",
            resource.title === "Alcumus (Pre-Algebra & Beyond)" && "resource-image-aops",
            [
              "Depth of Knowledge (Kaplinsky)",
              "Open Middle® (Johnson & Kaplinsky)",
              "Openers (Math for Love)",
              "Games (Math For Love)",
              "Rich Tasks (Math for Love)",
              "Professional Development (Math for Love)",
              "Curriculum (Math for Love)",
              "Award Winning Games (Math For Love)",
              "Visual Patterns (Nguyen)",
            ].includes(resource.title) && "resource-image-logo",
            resource.title === "Project Euler (Programming)" && "resource-image-portrait",
          ]
            .filter(Boolean)
            .join(" ");

          return (
            <article
              class="resource-card"
              data-resource-card
              data-audiences={resource.audiences.join(" ")}
              data-format={format}
              data-source={resource.source}
            >
              <a
                class="resource-card-link"
                href={resource.url}
                target="_blank"
                rel="noreferrer"
                title={resource.blurb}
                aria-label={`${displayTitle}. ${resource.blurb}`}
              >
                <span class="sr-only">{resource.blurb}</span>
              </a>

              <div class="resource-card-top">
                {
                  image ? (
                    <div class="resource-figure">
                      <img
                        class={imageClass}
                        src={image}
                        alt=""
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  ) : (
                    <div class="resource-figure resource-figure-fallback" aria-hidden="true">
                      <span>{format}</span>
                    </div>
                  )
                }

                <div class="resource-meta">
                  <button
                    class="resource-kind resource-filter-chip"
                    type="button"
                    data-filter-group="format"
                    data-filter-value={format}
                    aria-label={`Filter by format: ${format}`}
                  >
                    {format}
                  </button>
                  <button
                    class="resource-source resource-filter-chip"
                    type="button"
                    data-filter-group="source"
                    data-filter-value={resource.source}
                    aria-label={`Filter by source: ${resource.source}`}
                  >
                    {resource.source}
                  </button>
                </div>
                <h3>{displayTitle}</h3>
              </div>

              <div class="resource-card-bottom">
                <div class="resource-tag-row" aria-label={`Audiences for ${displayTitle}`}>
                  {resource.audiences.map((audience) => {
                    const label = audienceLabelById[audience];

                    return (
                      <button
                        class="resource-tag"
                        type="button"
                        data-filter-group="audience"
                        data-filter-value={audience}
                        aria-label={`Show only ${label?.toLowerCase()} resources`}
                      >
                        {label}
                      </button>
                    );
                  })}
                </div>
              </div>
            </article>
          );
        })
      }
    </div>

    <p class="resources-empty" data-resource-empty hidden>
      No resources match that combination yet.
    </p>

    <div class="source-profile" data-source-profile hidden>
      <p class="eyebrow">About This Source</p>
      <h2 data-source-profile-name></h2>
      <p class="source-profile-copy" data-source-profile-bio></p>
      <p class="source-profile-link-wrap" data-source-profile-link-wrap hidden>
        <a
          class="source-profile-link"
          data-source-profile-link
          href="#"
          target="_blank"
          rel="noreferrer"
        >
          Visit source
        </a>
      </p>
    </div>
  </section>
</BaseLayout>

<script define:vars={{ sourceProfiles: resourceSourceProfiles }}>
  const sourceProfilesMap = sourceProfiles;
  const resourceCards = Array.from(document.querySelectorAll("[data-resource-card]"));
  const emptyState = document.querySelector("[data-resource-empty]");
  const filterButtons = Array.from(document.querySelectorAll("[data-filter-group]"));
  const filterToggle = document.querySelector("[data-filter-toggle]");
  const filterPanel = document.querySelector("[data-filter-panel]");
  const activeFilters = document.querySelector("[data-active-filters]");
  const activeFilterSummary = document.querySelector("[data-active-filter-summary]");
  const clearFilterButtons = Array.from(document.querySelectorAll("[data-clear-filters]"));
  const sourceProfile = document.querySelector("[data-source-profile]");
  const sourceProfileName = document.querySelector("[data-source-profile-name]");
  const sourceProfileBio = document.querySelector("[data-source-profile-bio]");
  const sourceProfileLinkWrap = document.querySelector("[data-source-profile-link-wrap]");
  const sourceProfileLink = document.querySelector("[data-source-profile-link]");
  const filterGroupLabels = {
    audience: "Audience",
    format: "Format",
    source: "Source",
  };
  const filterState = {
    audience: [],
    format: [],
    source: [],
  };
  const validFilterValues = {
    audience: new Set(),
    format: new Set(),
    source: new Set(),
  };
  const filterLabels = {
    audience: {},
    format: {},
    source: {},
  };

  filterButtons.forEach((button) => {
    const group = button.getAttribute("data-filter-group");
    const value = button.getAttribute("data-filter-value");
    const label = button.textContent?.trim();

    if (group && value && group in validFilterValues) {
      validFilterValues[group].add(value);

      if (label && !filterLabels[group][value]) {
        filterLabels[group][value] = label;
      }
    }
  });

  const setFilterPanelOpen = (isOpen) => {
    if (!filterToggle || !filterPanel) {
      return;
    }

    filterToggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
    filterPanel.hidden = !isOpen;
  };

  const syncFiltersToUrl = () => {
    const nextUrl = new URL(window.location.href);

    Object.entries(filterState).forEach(([group, values]) => {
      nextUrl.searchParams.delete(group);

      values.forEach((value) => {
        nextUrl.searchParams.append(group, value);
      });
    });

    const search = nextUrl.searchParams.toString();
    const href = `${nextUrl.pathname}${search ? `?${search}` : ""}${nextUrl.hash}`;

    window.history.replaceState({}, "", href);
  };

  const initializeFiltersFromUrl = () => {
    const currentUrl = new URL(window.location.href);
    let shouldCleanUrl = false;

    Object.keys(filterState).forEach((group) => {
      const rawValues = currentUrl.searchParams.getAll(group);
      const values = [...new Set(rawValues)].filter((value) => validFilterValues[group]?.has(value));

      filterState[group] = values;

      if (values.length !== rawValues.length) {
        shouldCleanUrl = true;
      }
    });

    if (shouldCleanUrl) {
      syncFiltersToUrl();
    }
  };

  const updateResources = () => {
    let visibleCount = 0;

    resourceCards.forEach((card) => {
      const audiences = (card.getAttribute("data-audiences") ?? "").split(" ").filter(Boolean);
      const format = card.getAttribute("data-format");
      const source = card.getAttribute("data-source");
      const matchesAudience =
        filterState.audience.length === 0 ||
        filterState.audience.some((value) => audiences.includes(value));
      const matchesFormat =
        filterState.format.length === 0 ||
        filterState.format.includes(format);
      const matchesSource =
        filterState.source.length === 0 ||
        filterState.source.includes(source);
      const matches = matchesAudience && matchesFormat && matchesSource;

      card.toggleAttribute("hidden", !matches);

      if (matches) {
        visibleCount += 1;
      }
    });

    filterButtons.forEach((button) => {
      const group = button.getAttribute("data-filter-group");
      const value = button.getAttribute("data-filter-value");
      const isActive = group && value && filterState[group].includes(value);

      button.classList.toggle("is-active", Boolean(isActive));
      button.setAttribute("aria-pressed", isActive ? "true" : "false");
    });

    if (emptyState) {
      emptyState.toggleAttribute("hidden", visibleCount !== 0);
    }

    if (activeFilters && activeFilterSummary) {
      const activeFilterEntries = Object.entries(filterState).filter(([, values]) => values.length > 0);
      const hasActiveFilters = activeFilterEntries.length > 0;

      if (hasActiveFilters) {
        activeFilterSummary.textContent = activeFilterEntries
          .map(
            ([group, values]) =>
              `${filterGroupLabels[group]}: ${values
                .map((value) => filterLabels[group][value] ?? value)
                .join(", ")}`,
          )
          .join(" · ");
      } else {
        activeFilterSummary.textContent = "";
      }

      activeFilters.classList.toggle("is-empty", !hasActiveFilters);
      clearFilterButtons.forEach((button) => {
        button.disabled = !hasActiveFilters;
      });
    }

    if (
      sourceProfile &&
      sourceProfileName &&
      sourceProfileBio &&
      sourceProfileLinkWrap &&
      sourceProfileLink
    ) {
      const selectedSource = filterState.source.length === 1 ? filterState.source[0] : null;
      const profile = selectedSource ? sourceProfilesMap[selectedSource] : null;

      if (profile) {
        sourceProfileName.textContent = profile.name;
        sourceProfileBio.textContent = profile.bio;
        if (profile.url) {
          sourceProfileLink.href = profile.url;
          sourceProfileLink.textContent = `Visit ${profile.name}`;
          sourceProfileLinkWrap.hidden = false;
        } else {
          sourceProfileLinkWrap.hidden = true;
          sourceProfileLink.removeAttribute("href");
        }
        sourceProfile.hidden = false;
      } else {
        sourceProfile.hidden = true;
        sourceProfileLinkWrap.hidden = true;
      }
    }
  };

  const toggleFilter = (group, value) => {
    const nextValues = filterState[group].includes(value)
      ? filterState[group].filter((entry) => entry !== value)
      : [...filterState[group], value];

    filterState[group] = nextValues;
    syncFiltersToUrl();
    updateResources();
  };

  const clearFilters = () => {
    Object.keys(filterState).forEach((group) => {
      filterState[group] = [];
    });

    syncFiltersToUrl();
    updateResources();
  };

  filterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      const group = button.getAttribute("data-filter-group");
      const value = button.getAttribute("data-filter-value");

      if (group && value) {
        toggleFilter(group, value);
      }
    });
  });

  clearFilterButtons.forEach((button) => {
    button.addEventListener("click", () => {
      clearFilters();
    });
  });

  if (filterToggle) {
    filterToggle.addEventListener("click", () => {
      const isOpen = filterToggle.getAttribute("aria-expanded") === "true";
      setFilterPanelOpen(!isOpen);
    });
  }

  if (filterPanel) {
    document.addEventListener("click", (event) => {
      const target = event.target;

      if (!(target instanceof Node)) {
        return;
      }

      if (
        filterToggle?.contains(target) ||
        filterPanel.contains(target) ||
        filterPanel.hidden
      ) {
        return;
      }

      setFilterPanelOpen(false);
    });

    document.addEventListener("keydown", (event) => {
      if (event.key === "Escape" && !filterPanel.hidden) {
        setFilterPanelOpen(false);
        filterToggle?.focus();
      }
    });
  }

  initializeFiltersFromUrl();
  updateResources();
</script>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .resources-panel {
    display: grid;
    gap: 0.35rem;
  }

  .resources-intro h1 {
    max-width: none;
  }

  .resources-intro {
    position: relative;
    display: grid;
    gap: 0.35rem;
    z-index: 12;
  }

  .resources-intro-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .resources-intro-header h1 {
    max-width: 9ch;
  }

  .resources-intro-controls {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .resources-filter-toggle,
  .resources-clear-button,
  .resource-filter-option {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    border: 0;
    border-radius: 999px;
    font: inherit;
    font-weight: 700;
    line-height: 1.2;
    cursor: pointer;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      color 180ms ease,
      box-shadow 180ms ease;
  }

  .resources-filter-toggle,
  .resources-clear-button {
    min-height: 3rem;
    padding: 0.45rem 1.1rem;
  }

  .resources-filter-toggle {
    position: relative;
    color: var(--cream-bright);
    background:
      radial-gradient(circle at top left, rgba(244, 201, 107, 0.22), transparent 42%),
      linear-gradient(135deg, var(--moss-panel-top), var(--moss-panel-bottom));
    box-shadow:
      0 16px 32px rgba(47, 71, 52, 0.16),
      inset 0 0 0 1px rgba(255, 255, 255, 0.08);
    letter-spacing: 0.01em;
  }

  .resources-filter-toggle:hover,
  .resources-filter-toggle:focus-visible,
  .resources-clear-button:hover,
  .resources-clear-button:focus-visible,
  .resource-filter-option:hover,
  .resource-filter-option:focus-visible {
    transform: translateY(-1px);
  }

  .resources-filter-toggle:hover,
  .resources-filter-toggle:focus-visible {
    box-shadow:
      0 20px 36px rgba(47, 71, 52, 0.2),
      inset 0 0 0 1px rgba(255, 255, 255, 0.12);
  }

  .resources-filter-toggle:focus-visible,
  .resources-clear-button:focus-visible,
  .resource-filter-option:focus-visible {
    outline: 2px solid rgba(200, 109, 75, 0.5);
    outline-offset: 3px;
  }

  .resources-filter-toggle[aria-expanded="true"] {
    color: var(--cream-bright);
    background:
      radial-gradient(circle at top left, rgba(255, 240, 204, 0.22), transparent 38%),
      linear-gradient(135deg, var(--clay), var(--clay-deep));
    box-shadow:
      0 18px 34px rgba(200, 109, 75, 0.22),
      inset 0 0 0 1px rgba(255, 255, 255, 0.14);
  }

  .resources-filter-icon {
    flex: none;
    width: 2rem;
    height: 2rem;
    padding: 0.35rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.12);
    transition:
      transform 180ms ease,
      background-color 180ms ease;
  }

  .resources-filter-toggle[aria-expanded="true"] .resources-filter-icon {
    transform: rotate(10deg);
    background: rgba(255, 255, 255, 0.18);
  }

  .resources-active-filters {
    display: flex;
    align-items: center;
    min-height: 2rem;
    padding: 0.15rem 0.1rem 0.1rem;
  }

  .resources-active-filters.is-empty .resources-active-summary::before {
    content: "";
  }

  .resources-active-summary {
    margin: 0;
    color: var(--moss);
    font-size: 0.95rem;
    font-weight: 700;
    line-height: 1.3;
  }

  .resources-clear-button {
    color: var(--clay-deep);
    background: rgba(255, 250, 242, 0.9);
    box-shadow:
      inset 0 0 0 1px rgba(200, 109, 75, 0.16),
      0 10px 20px rgba(200, 109, 75, 0.08);
  }

  .resources-clear-button:disabled {
    cursor: default;
    opacity: 0.48;
    transform: none;
    box-shadow: inset 0 0 0 1px rgba(200, 109, 75, 0.1);
  }

  .resources-filter-panel {
    position: relative;
    overflow: hidden;
    position: absolute;
    top: calc(100% + 0.2rem);
    right: 0;
    z-index: 20;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.2rem;
    padding: 1.4rem 1.3rem 1.35rem;
    width: min(38rem, calc(100vw - 3rem));
    border-radius: var(--radius-xl);
    background:
      radial-gradient(circle at top right, rgba(244, 201, 107, 0.22), transparent 28%),
      radial-gradient(circle at left center, rgba(108, 138, 83, 0.12), transparent 24%),
      linear-gradient(180deg, rgba(255, 252, 245, 0.97), rgba(237, 244, 229, 0.96));
    box-shadow:
      var(--shadow),
      inset 0 0 0 1px rgba(108, 138, 83, 0.1);
  }

  .resources-filter-panel[hidden] {
    display: none;
  }

  .resources-filter-panel::after {
    content: "";
    position: absolute;
    right: -2.5rem;
    bottom: -2.75rem;
    width: 9rem;
    height: 9rem;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(244, 201, 107, 0.24), rgba(244, 201, 107, 0));
    pointer-events: none;
  }

  .resources-filter-group {
    display: grid;
    gap: 0.75rem;
    align-content: start;
  }

  .resources-filter-group .eyebrow {
    margin: 0;
    color: var(--clay-deep);
  }

  .resources-filter-options {
    display: grid;
    gap: 0.5rem;
  }

  .resource-filter-option {
    justify-content: flex-start;
    min-height: 2.65rem;
    padding: 0.5rem 0.95rem;
    color: var(--moss);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.9), rgba(247, 242, 230, 0.9));
    box-shadow:
      inset 0 0 0 1px rgba(108, 138, 83, 0.16),
      0 8px 18px rgba(31, 42, 31, 0.05);
  }

  .resource-filter-option.is-active {
    color: var(--cream-bright);
    background:
      radial-gradient(circle at top left, rgba(255, 240, 204, 0.2), transparent 42%),
      linear-gradient(135deg, var(--clay), var(--clay-deep));
    box-shadow:
      0 12px 24px rgba(200, 109, 75, 0.18),
      inset 0 0 0 1px rgba(255, 255, 255, 0.14);
  }

  .resources-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .source-profile {
    display: grid;
    gap: 0.55rem;
    padding: 1.5rem 1.65rem;
    margin-top: 1rem;
    border-radius: var(--radius-xl);
    background: linear-gradient(135deg, rgba(219, 232, 208, 0.72), rgba(252, 245, 219, 0.88));
    box-shadow: var(--shadow);
  }

  .source-profile[hidden] {
    display: none;
  }

  .source-profile h2 {
    font-size: clamp(1.55rem, 2.5vw, 2.1rem);
    line-height: 1.02;
  }

  .source-profile-copy {
    margin: 0;
    max-width: 56rem;
    color: var(--muted);
  }

  .source-profile-link-wrap {
    margin: 0.1rem 0 0;
  }

  .source-profile-link {
    color: var(--moss);
    font-weight: 700;
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.16em;
  }

  .resource-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 1.4rem;
    min-height: 100%;
    padding: 1.35rem;
    border-radius: var(--radius-xl);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.96), rgba(250, 246, 236, 0.92));
    box-shadow: var(--shadow);
    cursor: pointer;
  }

  .resource-card[hidden] {
    display: none;
  }

  .resource-card-link {
    position: absolute;
    inset: 0;
    z-index: 1;
    border-radius: inherit;
  }

  .resource-card-link:focus-visible {
    outline: 2px solid rgba(200, 109, 75, 0.5);
    outline-offset: 3px;
  }

  .resource-card-top,
  .resource-card-bottom {
    position: relative;
    z-index: 2;
    display: grid;
    gap: 0.9rem;
    pointer-events: none;
  }

  .resource-figure {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 20px;
    background: linear-gradient(135deg, rgba(108, 138, 83, 0.22), rgba(244, 201, 107, 0.28));
    box-shadow: inset 0 0 0 1px rgba(54, 84, 59, 0.08);
  }

  .resource-figure-fallback {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    color: var(--moss);
    font-family: "Fraunces", Georgia, serif;
    font-size: 1.15rem;
    text-align: center;
  }

  .resource-image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .resource-image-aops {
    object-position: left center;
    transform: scale(2.05);
    transform-origin: left center;
  }

  .resource-image-logo,
  .resource-image-portrait {
    object-fit: contain;
    padding: 0.65rem 0.85rem;
  }

  .resource-meta,
  .resource-tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .resource-kind,
  .resource-source,
  .resource-tag {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 1.9rem;
    padding: 0.2rem 0.65rem;
