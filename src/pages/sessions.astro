---
import BaseLayout from "../layouts/BaseLayout.astro";

const sessions = [
  {
    title: "Family Math Garden: Babies & Toddlers",
    audience: "Ages 0-3 with caregiver",
    date: "Thursday, May 21",
    time: "10:00-10:40 AM",
    price: "$20 family",
    capacity: "6-8 families",
    category: "Family Math",
    blurb:
      "Playful early math through rhythm, movement, counting, spatial language, objects, and songs. This is as much for parents as for children: a gentle way to begin seeing math in everyday play.",
    stripeUrl: "TODO_STRIPE_FAMILY_MATH_BABIES_TODDLERS_MAY_21",
  },
  {
    title: "Preschool Math Garden",
    audience: "Ages 3-5 with caregiver",
    date: "Thursday, May 21",
    time: "11:15 AM-12:00 PM",
    price: "$20 family",
    capacity: "6-8 families",
    category: "Young Children",
    blurb:
      "Patterns, blocks, stories, games, sorting, shape, number, and mathematical conversation for young children who are ready to play with ideas.",
    stripeUrl: "TODO_STRIPE_PRESCHOOL_MATH_GARDEN_MAY_21",
  },
  {
    title: "Family Math Open Studio",
    audience: "Mixed ages, best for families with children 4-12",
    date: "Saturday, May 23",
    time: "10:00-11:30 AM",
    price: "$15 family",
    capacity: "8-12 families",
    category: "Open Studio",
    blurb:
      "A low-pressure first visit with games, puzzles, and mathematical play stations. Good for families who want to see the space before choosing a recurring session.",
    stripeUrl: "TODO_STRIPE_FAMILY_MATH_OPEN_STUDIO_MAY_23",
  },
  {
    title: "Math Studio: Early Elementary",
    audience: "Ages 5-8",
    date: "Tuesday, May 26",
    time: "3:45-4:45 PM",
    price: "$30 student",
    capacity: "6-8 students",
    category: "Math Studio",
    blurb:
      "Games, puzzles, number sense, pattern, and joyful problem solving for children ready to think, play, and explain.",
    stripeUrl: "TODO_STRIPE_EARLY_ELEMENTARY_MATH_STUDIO_MAY_26",
  },
  {
    title: "Chess & Strategy Games",
    audience: "Ages 7-12",
    date: "Wednesday, May 27",
    time: "4:00-5:15 PM",
    price: "$30 student",
    capacity: "8-10 students",
    category: "Games & Strategy",
    blurb:
      "Chess, card games, logic games, and strategy puzzles. A friendly studio session for focus, planning, flexible thinking, and good gamesmanship.",
    stripeUrl: "TODO_STRIPE_CHESS_STRATEGY_GAMES_MAY_27",
  },
  {
    title: "Math Studio: Problem Solvers",
    audience: "Ages 8-12",
    date: "Thursday, May 28",
    time: "4:00-5:15 PM",
    price: "$30 student",
    capacity: "6-8 students",
    category: "Math Studio",
    blurb:
      "Rich problems, puzzles, conjectures, and mathematical surprises for students ready for deeper challenge without acceleration theater.",
    stripeUrl: "TODO_STRIPE_PROBLEM_SOLVERS_MAY_28",
  },
  {
    title: "Diffy Squares Workshop",
    audience: "Ages 8-12, or younger by fit",
    date: "Saturday, May 30",
    time: "1:00-2:15 PM",
    price: "$30 student",
    capacity: "6-8 students",
    category: "Workshop",
    blurb:
      "A hands-on version of the Diffy Squares experience: simple rules, surprising patterns, conjectures, and the question, does it always go to zero?",
    stripeUrl: "TODO_STRIPE_DIFFY_SQUARES_WORKSHOP_MAY_30",
  },
  {
    title: "Rhythm, Pattern, Number",
    audience: "Ages 3-6 with caregiver optional",
    date: "Thursday, June 4",
    time: "10:30-11:15 AM",
    price: "$20 family",
    capacity: "6-8 families",
    category: "Music & Math",
    blurb:
      "A music-and-math session built around rhythm, clapping games, patterns, movement, and playful structure.",
    stripeUrl: "TODO_STRIPE_RHYTHM_PATTERN_NUMBER_JUNE_4",
  },
];

const series = [
  {
    title: "Early Math Garden",
    audience: "Ages 5-8",
    dates: "Tuesdays, June 2, 9, 16, 23",
    time: "3:45-4:45 PM",
    price: "$120 student",
    capacity: "6-8 students",
    blurb:
      "A four-week pilot rhythm for games, number sense, patterns, and mathematical conversation inside a warm studio culture.",
    stripeUrl: "TODO_STRIPE_EARLY_MATH_GARDEN_JUNE_SERIES",
  },
  {
    title: "Problem Studio",
    audience: "Ages 8-12",
    dates: "Thursdays, June 4, 11, 18, 25",
    time: "4:00-5:15 PM",
    price: "$120 student",
    capacity: "6-8 students",
    blurb:
      "A four-week pilot for rich problems, conjectures, proof-flavored thinking, and challenge that stays playful.",
    stripeUrl: "TODO_STRIPE_PROBLEM_STUDIO_JUNE_SERIES",
  },
  {
    title: "Chess & Strategy Studio",
    audience: "Ages 7-12",
    dates: "Wednesdays, June 3, 10, 17, 24",
    time: "4:00-5:15 PM",
    price: "$120 student",
    capacity: "8-10 students",
    blurb:
      "A four-week pilot for chess, card games, logic games, and strategic thinking in a friendly studio setting.",
    stripeUrl: "TODO_STRIPE_CHESS_STRATEGY_JUNE_SERIES",
  },
];
---

<BaseLayout
  title="Upcoming Sessions"
  description="Upcoming founding-season sessions at The Number Garden, beginning May 21, 2026."
>
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Upcoming Sessions</p>
      <h1>A real calendar for the first season.</h1>
      <p class="lede">
        The Number Garden is opening with a small founding-season calendar
        beginning Thursday, May 21. These first sessions are real opportunities
        to visit the studio, meet the work, and help shape the rhythms that
        become recurring programs.
      </p>
      <div class="actions">
        <a class="button button-primary" href="#single-sessions">
          See sessions
        </a>
        <a class="button button-secondary" href="/contact/">
          Ask about fit
        </a>
      </div>
    </div>

    <aside class="hero-card" aria-label="How founding-season sessions work">
      <p class="card-label">Founding season</p>
      <ul>
        <li>First sessions begin May 21, after studio setup</li>
        <li>Small groups with clear age ranges and capacities</li>
        <li>Direct registration links will use Stripe</li>
        <li>June pilot series may become recurring studio rhythms</li>
      </ul>
    </aside>
  </section>

  <section class="panel panel-light">
    <div class="section-heading">
      <p class="eyebrow">Registering</p>
      <h2>Choose a real session.</h2>
    </div>
    <p class="supporting-copy">
      Each listing will connect to its own Stripe registration link once the
      first calendar is finalized. For now, the links are intentionally marked
      as TODO placeholders while the schedule, prices, and capacities are under
      review.
    </p>
    <p class="supporting-copy">
      If you are not sure where to begin, the contact form is still the best
      first step.
    </p>
    <div class="inline-links">
      <a class="card-link" href="/contact/">
        Ask about fit
      </a>
    </div>
  </section>

  <section class="panel panel-accent" id="single-sessions">
    <div class="section-heading">
      <p class="eyebrow">May And Early June</p>
      <h2>Single sessions and workshops.</h2>
    </div>
    <div class="session-grid" aria-label="Upcoming single sessions">
      {sessions.map((session) => (
        <article class="session-card">
          <div class="session-card-top">
            <p class="session-category">{session.category}</p>
            <h3>{session.title}</h3>
          </div>
          <dl class="session-details">
            <div>
              <dt>Date</dt>
              <dd>{session.date}</dd>
            </div>
            <div>
              <dt>Time</dt>
              <dd>{session.time}</dd>
            </div>
            <div>
              <dt>Age</dt>
              <dd>{session.audience}</dd>
            </div>
            <div>
              <dt>Price</dt>
              <dd>{session.price}</dd>
            </div>
            <div>
              <dt>Capacity</dt>
              <dd>{session.capacity}</dd>
            </div>
          </dl>
          <p>{session.blurb}</p>
          <a
            class="card-link session-link is-todo"
            href={`#${session.stripeUrl}`}
            aria-label={`Stripe registration link TODO for ${session.title}`}
          >
            TODO Stripe link
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="panel panel-light">
    <div class="section-heading">
      <p class="eyebrow">June Pilots</p>
      <h2>Four-week studio rhythms.</h2>
    </div>
    <p class="supporting-copy">
      These June series are the first candidates for recurring studio rhythms.
      The exact shape can still change as the first families and students come
      into view.
    </p>
    <div class="session-grid" aria-label="June pilot series">
      {series.map((item) => (
        <article class="session-card">
          <div class="session-card-top">
            <p class="session-category">June Series</p>
            <h3>{item.title}</h3>
          </div>
          <dl class="session-details">
            <div>
              <dt>Dates</dt>
              <dd>{item.dates}</dd>
            </div>
            <div>
              <dt>Time</dt>
              <dd>{item.time}</dd>
            </div>
            <div>
              <dt>Age</dt>
              <dd>{item.audience}</dd>
            </div>
            <div>
              <dt>Price</dt>
              <dd>{item.price}</dd>
            </div>
            <div>
              <dt>Capacity</dt>
              <dd>{item.capacity}</dd>
            </div>
          </dl>
          <p>{item.blurb}</p>
          <a
            class="card-link session-link is-todo"
            href={`#${item.stripeUrl}`}
            aria-label={`Stripe registration link TODO for ${item.title}`}
          >
            TODO Stripe link
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="panel panel-accent contact-panel">
    <div class="section-heading">
      <p class="eyebrow">Not Sure?</p>
      <h2>Start with fit.</h2>
    </div>
    <p class="contact-copy">
      If you are choosing for more than one child, wondering about age fit, or
      trying to find the right first visit, send a note and I will help you
      choose a good place to begin.
    </p>
    <a class="contact-link" href="/contact/">
      Ask about fit
    </a>
  </section>
</BaseLayout>

<style>
  .session-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .session-card {
    display: grid;
    align-content: start;
    gap: 1rem;
    padding: 1.5rem;
    border-radius: var(--radius-xl);
    background: rgba(255, 255, 255, 0.78);
    box-shadow: var(--shadow);
  }

  .session-card-top {
    display: grid;
    gap: 0.45rem;
  }

  .session-category {
    margin: 0;
    color: var(--clay);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .session-details {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.75rem;
    margin: 0;
    padding: 0;
  }

  .session-details div {
    min-width: 0;
  }

  .session-details dt {
    margin: 0 0 0.15rem;
    color: var(--moss);
    font-size: 0.78rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .session-details dd {
    margin: 0;
    color: var(--muted);
    font-size: 0.96rem;
    line-height: 1.45;
  }

  .session-card p {
    margin: 0;
    color: var(--muted);
  }

  .session-link {
    justify-self: start;
    margin-top: 0.25rem;
  }

  .is-todo {
    border: 1px dashed rgba(54, 84, 59, 0.35);
  }

  @media (max-width: 820px) {
    .session-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 560px) {
    .session-details {
      grid-template-columns: 1fr;
    }

    .session-link {
      justify-self: stretch;
    }
  }
</style>
