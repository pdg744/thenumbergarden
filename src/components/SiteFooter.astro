---
import { formatStudioAddress, mailtoHref, siteConfig } from "../config/site";

const footerAddress = formatStudioAddress({ includeRegion: true });
---

<footer class="site-footer">
  <div class="footer-brand">
    <p class="footer-title">
      <img class="footer-mark" src={siteConfig.logoPath} alt="" width="32" height="32" />
      <span>{siteConfig.name}</span>
    </p>
    <p class="footer-address">
      <a
        href={siteConfig.mapUrl}
        target="_blank"
        rel="noreferrer"
        data-ga-event="map_click"
        data-ga-label="Footer address map"
      >
        <span class="footer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path
              d="M12 22s7-6.2 7-12a7 7 0 1 0-14 0c0 5.8 7 12 7 12Zm0-9a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"
              fill="currentColor"
            />
          </svg>
        </span>
        <span>{footerAddress}</span>
      </a>
    </p>
    <p class="footer-contact">
      <a
        href={mailtoHref(siteConfig.contactEmail)}
        data-ga-event="email_click"
        data-ga-label="Footer email"
      >
        <span class="footer-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" focusable="false">
            <path
              d="M4 6.75A2.75 2.75 0 0 1 6.75 4h10.5A2.75 2.75 0 0 1 20 6.75v10.5A2.75 2.75 0 0 1 17.25 20H6.75A2.75 2.75 0 0 1 4 17.25V6.75Zm2.75-1.25c-.32 0-.61.12-.83.31l5.3 5.3a1.1 1.1 0 0 0 1.56 0l5.3-5.3a1.24 1.24 0 0 0-.83-.31H6.75Zm11.75 2.02-4.66 4.65a2.6 2.6 0 0 1-3.68 0L5.5 7.52v9.73c0 .69.56 1.25 1.25 1.25h10.5c.69 0 1.25-.56 1.25-1.25V7.52Z"
              fill="currentColor"
            />
          </svg>
        </span>
        <span>{siteConfig.contactEmail}</span>
      </a>
    </p>
  </div>

  <nav class="footer-nav" aria-label="Footer navigation">
    <div class="footer-link-group">
      <p class="footer-group-title">Studio</p>
      <a href="/about/">About</a>
      <a href="/membership/">Membership</a>
      <a href="/resources/">Resources</a>
    </div>

    <div class="footer-link-group">
      <p class="footer-group-title">For families</p>
      <a
        href="/portland-math-tutor/"
        data-ga-event="tutor_page_click"
        data-ga-label="Footer math tutoring"
      >
        Math tutoring in Portland
      </a>
      <a
        href="/portland-math-camp/"
        data-ga-event="camp_page_click"
        data-ga-label="Footer August math camp"
      >
        August math camp
      </a>
      <a href="/family-visit/">Book a Visit</a>
    </div>
  </nav>
</footer>
