---
import "../styles/brand.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const siteTitle = "The Number Garden";
const fullTitle = title === siteTitle ? siteTitle : `${title} | ${siteTitle}`;

const normalizePath = (path: string) => {
  if (!path || path === "/") {
    return "/";
  }

  return path.endsWith("/") ? path : `${path}/`;
};

const currentPath = normalizePath(Astro.url.pathname);
const isCurrent = (href: string) => currentPath === href;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? "https://thenumbergarden.com");
const socialImageUrl = new URL("/social-preview.png", Astro.site ?? "https://thenumbergarden.com");
const socialImageAlt = "The Number Garden logo mark beside The Number Garden wordmark.";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta property="og:site_name" content={siteTitle} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl.toString()} />
    <meta property="og:image" content={socialImageUrl.toString()} />
    <meta property="og:image:alt" content={socialImageAlt} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl.toString()} />
    <meta name="twitter:image:alt" content={socialImageAlt} />
    <link rel="canonical" href={canonicalUrl.toString()} />
    <slot name="head" />
    <title>{fullTitle}</title>
  </head>
  <body>
    <div class="page-shell">
      <header class="topbar">
        <a class="wordmark" href="/">
          <img class="wordmark-mark" src="/brand/logo-mark.svg" alt="" width="48" height="48" />
          <span>The Number Garden</span>
        </a>
        <nav class="primary-nav" aria-label="Primary navigation">
          <a class:list={["nav-link", isCurrent("/about/") && "is-current"]} href="/about/">
            About
          </a>

          <a class:list={["nav-link", isCurrent("/resources/") && "is-current"]} href="/resources/">
            Resources
          </a>

          <a
            class:list={["nav-link", isCurrent("/membership/") && "is-current"]}
            href="/membership/"
          >
            Membership
          </a>

          <a
            class:list={["nav-link", "nav-cta", isCurrent("/family-visit/") && "is-current"]}
            href="/family-visit/"
          >
            Book a Visit
          </a>
        </nav>
      </header>

      <main class="page-main">
        <slot />
      </main>

      <footer class="site-footer">
        <div class="footer-block">
          <p class="footer-title">
            <img class="footer-mark" src="/brand/logo-mark.svg" alt="" width="32" height="32" />
            <span>The Number Garden</span>
          </p>
          <p class="footer-address">
            <a
              href="https://maps.google.com/?q=1717+NE+42nd+Ave+Suite+0100B+Portland+OR"
              target="_blank"
              rel="noreferrer"
            >
              <span class="footer-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                  <path
                    d="M12 22s7-6.2 7-12a7 7 0 1 0-14 0c0 5.8 7 12 7 12Zm0-9a3 3 0 1 1 0-6 3 3 0 0 1 0 6Z"
                    fill="currentColor"
                  />
                </svg>
              </span>
              <span>1717 NE 42nd Ave Suite 0100B, Portland, OR</span>
            </a>
          </p>
        </div>
        <div class="footer-block footer-block-right">
          <p class="footer-title">What questions do you have?</p>
          <p class="footer-copy">
            E-mail Paul at
            <a href="mailto:paul@thenumbergarden.com">
              paul@thenumbergarden.com
            </a>
          </p>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  @import url("https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,700&family=Manrope:wght@400;500;600;700;800&display=swap");

  html {
    scroll-behavior: smooth;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
  }

  body {
    margin: 0;
    font-family: "Manrope", "Avenir Next", "Segoe UI", sans-serif;
    color: var(--ink);
    background:
      radial-gradient(circle at top left, rgba(244, 201, 107, 0.4), transparent 28%),
      radial-gradient(circle at 85% 12%, rgba(108, 138, 83, 0.23), transparent 24%),
      linear-gradient(180deg, var(--paper-top) 0%, var(--paper-bottom) 100%);
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  .page-shell {
    width: min(1120px, calc(100vw - 2rem));
    margin: 0 auto;
    padding: 1.25rem 0 4rem;
  }

  .topbar,
  .hero,
  .panel,
  .card-grid {
    animation: rise 700ms ease-out both;
  }

  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.75rem;
    position: relative;
    z-index: 20;
  }

  .wordmark {
    display: inline-flex;
    align-items: center;
    gap: 0.72rem;
    font-family: "Fraunces", Georgia, serif;
    font-size: 1.4rem;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  .wordmark-mark {
    width: 2.9rem;
    height: 2.9rem;
    flex: 0 0 auto;
    display: block;
  }

  .primary-nav {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.96rem;
    color: var(--muted);
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    min-height: 2.5rem;
    padding: 0.35rem 0.05rem;
    font-weight: 700;
    cursor: pointer;
    transition:
      transform 180ms ease,
      color 180ms ease;
  }

  .nav-cta {
    padding: 0.7rem 1rem;
    border-radius: 999px;
    color: var(--cream-bright);
    background: linear-gradient(135deg, var(--clay), var(--clay-deep));
    box-shadow:
      0 14px 28px rgba(200, 109, 75, 0.22),
      inset 0 0 0 1px rgba(255, 255, 255, 0.1);
  }

  .nav-link:hover,
  .nav-link:focus-visible,
  .button:hover,
  .button:focus-visible,
  .contact-link:hover,
  .contact-link:focus-visible,
  .card-link:hover,
  .card-link:focus-visible {
    transform: translateY(-1px);
  }

  .nav-link:focus-visible,
  .button:focus-visible,
  .contact-link:focus-visible,
  .card-link:focus-visible {
    outline: 2px solid rgba(200, 109, 75, 0.5);
    outline-offset: 3px;
  }

  .is-current,
  .nav-link.is-current {
    color: var(--moss);
  }

  .nav-link.nav-cta.is-current {
    color: var(--cream-bright);
  }

  .page-main {
    display: grid;
    gap: 1.25rem;
  }

  .site-footer {
    display: flex;
    justify-content: space-between;
    gap: 2rem;
    margin-top: 2rem;
    padding: 0 0.35rem;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .site-footer p {
    margin: 0;
  }

  .footer-block {
    display: grid;
    gap: 0.45rem;
  }

  .footer-block-right {
    justify-items: end;
    text-align: right;
  }

  .footer-title {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    color: var(--ink);
    font-weight: 700;
    font-size: 1.25rem;
    line-height: 1.15;
  }

  .footer-mark {
    width: 2rem;
    height: 2rem;
    flex: 0 0 auto;
    display: block;
  }

  .footer-copy a,
  .footer-address a {
    color: var(--moss);
    text-decoration: none;
  }

  .footer-address a {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }

  .footer-icon {
    display: inline-flex;
    width: 1rem;
    height: 1rem;
    flex: 0 0 auto;
  }

  .footer-icon svg {
    width: 100%;
    height: 100%;
  }

  .hero {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.8fr);
    gap: 1.5rem;
  }

  .hero-copy,
  .hero-card,
  .panel,
  .topic-card {
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow);
  }

  .hero-copy {
    padding: 3.25rem;
    background:
      radial-gradient(circle at top right, rgba(244, 201, 107, 0.32), transparent 26%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.9), rgba(250, 246, 236, 0.94));
  }

  .hero-card {
    padding: 2rem;
    background: linear-gradient(180deg, var(--moss-gradient-top) 0%, var(--moss-gradient-bottom) 100%);
    color: var(--paper-inverse);
    align-self: stretch;
  }

  .eyebrow,
  .card-label {
    margin: 0 0 0.75rem;
    font-size: 0.82rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .eyebrow {
    color: var(--clay);
  }

  .card-label {
    color: var(--sage-bright);
  }

  h1,
  h2,
  h3 {
    margin: 0;
    font-family: "Fraunces", Georgia, serif;
    font-weight: 600;
    letter-spacing: -0.03em;
  }

  h1 {
    max-width: 12ch;
    font-size: clamp(3rem, 6vw, 5.4rem);
    line-height: 0.95;
  }

  h2 {
    font-size: clamp(2rem, 3vw, 3rem);
    line-height: 1;
  }

  h3 {
    font-size: 1.35rem;
    line-height: 1.1;
  }

  p,
  li {
    font-size: 1.02rem;
    line-height: 1.7;
  }

  .lede,
  .section-copy,
  .supporting-copy,
  .contact-copy {
    color: var(--muted);
  }

  .lede {
    max-width: 38rem;
    margin: 1.25rem 0 0;
    font-size: 1.12rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  .button,
  .contact-link,
  .card-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.3rem;
    padding: 0 1.3rem;
    border-radius: 999px;
    font-weight: 700;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .button-primary,
  .contact-link {
    background: var(--moss);
    color: var(--paper-inverse-strong);
  }

  .button-secondary {
    background: rgba(54, 84, 59, 0.08);
    color: var(--ink);
  }

  .button-large {
    min-height: 4.25rem;
    padding: 0 2rem;
    font-size: 1.08rem;
  }

  .signup-form {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.85rem;
    align-items: end;
    width: min(100%, 38rem);
    margin: 0 auto;
  }

  .signup-form-field {
    display: grid;
    gap: 0.45rem;
    text-align: left;
  }

  .signup-form label {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--ink);
  }

  .signup-form input[type="email"] {
    min-height: 3.3rem;
    padding: 0 1rem;
    border: 1px solid rgba(54, 84, 59, 0.24);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.9);
    color: var(--ink);
    font: inherit;
  }

  .signup-form input[type="submit"] {
    min-height: 3.3rem;
    padding: 0 1.3rem;
    border: 0;
    border-radius: 999px;
    background: var(--moss);
    color: var(--paper-inverse-strong);
    font: inherit;
    font-weight: 700;
    cursor: pointer;
    transition:
      transform 180ms ease,
      background-color 180ms ease,
      color 180ms ease;
  }

  .signup-form input[type="submit"]:hover,
  .signup-form input[type="submit"]:focus-visible {
    transform: translateY(-1px);
  }

  .signup-form input[type="submit"]:focus-visible,
  .signup-form input[type="email"]:focus-visible {
    outline: 2px solid rgba(200, 109, 75, 0.5);
    outline-offset: 3px;
  }

  .signup-note {
    margin: 1rem auto 0;
    max-width: 38rem;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .signup-note a {
    color: var(--moss);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 0.16em;
  }

  .hero-card ul {
    margin: 0;
    padding-left: 1.1rem;
  }

  .hero-card li + li {
    margin-top: 0.8rem;
  }

  .hero-card li {
    color: inherit;
  }

  .card-grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
  }

  .topic-card {
    padding: 1.5rem;
    background: rgba(255, 255, 255, 0.78);
  }

  .topic-card p {
    margin: 0.85rem 0 1.25rem;
    color: var(--muted);
  }

  .card-link {
    min-height: 2.85rem;
    padding: 0 1rem;
    background: rgba(54, 84, 59, 0.08);
    color: var(--moss);
  }

  .panel {
    padding: 2.3rem;
  }

  .panel-light {
    background: rgba(255, 255, 255, 0.78);
  }

  .panel-accent {
    background: linear-gradient(135deg, rgba(219, 232, 208, 0.82), rgba(252, 245, 219, 0.88));
  }

  .panel-dark {
    background: linear-gradient(135deg, var(--moss-panel-top) 0%, var(--moss-panel-bottom) 100%);
    color: var(--paper-inverse);
  }

  .section-heading {
    display: grid;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .content-stack {
    display: grid;
    gap: 1.6rem;
  }

  .experience-embed {
    display: grid;
    gap: 1rem;
    margin-top: 1rem;
  }

  .experience-frame {
    width: 100%;
    min-height: 640px;
    border: 0;
    border-radius: var(--radius-lg);
    background: rgba(255, 255, 255, 0.88);
    box-shadow: inset 0 0 0 1px var(--line);
  }

  .form-frame {
    min-height: 2444px;
    height: 2444px;
  }

  .app-frame {
    min-height: 760px;
    height: 760px;
  }

  .app-shell {
    width: min(100%, 440px);
    margin: 0 auto;
    padding: 14px;
    border-radius: 32px;
    background:
      linear-gradient(180deg, rgba(31, 42, 31, 0.92), rgba(18, 24, 18, 0.96));
    box-shadow:
      0 28px 60px rgba(31, 42, 31, 0.18),
      inset 0 0 0 1px rgba(255, 255, 255, 0.06);
  }

  .launch-card {
    max-width: 34rem;
    margin: 0 auto;
    text-align: center;
  }

  .launch-button {
    border: 0;
    cursor: pointer;
    font: inherit;
  }

  .inline-experience[hidden] {
    display: none;
  }

  .experience-note {
    margin: 0;
    color: var(--muted);
  }

  .section-block {
    padding-top: 1.4rem;
    border-top: 1px solid var(--line);
  }

  .section-block:first-child {
    padding-top: 0;
    border-top: 0;
  }

  .section-block p {
    margin: 0.75rem 0 0;
  }

  .prompt {
    margin-top: 0.85rem;
    color: var(--moss);
    font-weight: 700;
  }

  .inline-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.25rem;
  }

  .quote-block {
    display: grid;
    gap: 0.75rem;
    max-width: 52rem;
  }

  .quote-mark {
    margin: 0;
    font-family: "Fraunces", Georgia, serif;
    font-size: 4.5rem;
    line-height: 0.8;
    color: var(--grid);
  }

  .quote {
    margin: 0;
    color: var(--paper-inverse);
    font-size: clamp(1.25rem, 2vw, 1.7rem);
    line-height: 1.5;
  }

  .contact-panel {
    text-align: center;
  }

  .contact-panel .section-heading {
    justify-items: center;
  }

  .contact-copy {
    max-width: 40rem;
    margin: 0 auto 1.25rem;
  }

  @keyframes rise {
    from {
      opacity: 0;
      transform: translateY(16px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 980px) {
    .hero,
    .card-grid {
      grid-template-columns: 1fr;
    }

    .hero-copy,
    .hero-card,
    .panel {
      padding: 1.75rem;
    }

    .topbar {
      flex-direction: column;
      align-items: flex-start;
    }

    .site-footer {
      flex-direction: column;
    }

    .footer-block-right {
      justify-items: start;
      text-align: left;
    }
  }

  @media (max-width: 720px) {
    .dropdown-menu {
      position: static;
      margin-top: 0.35rem;
      min-width: min(16rem, calc(100vw - 3rem));
    }
  }

  @media (max-width: 560px) {
    .page-shell {
      width: min(100vw - 1rem, 1120px);
      padding-top: 0.75rem;
      padding-bottom: 2.5rem;
    }

    .primary-nav {
      gap: 0.75rem;
      font-size: 0.9rem;
    }

    .hero-copy,
    .hero-card,
    .panel,
    .topic-card {
      padding: 1.35rem;
      border-radius: 28px;
    }

    .actions,
    .inline-links,
    .signup-form {
      flex-direction: column;
    }

    .signup-form {
      grid-template-columns: 1fr;
    }

    .form-frame {
      min-height: 2600px;
      height: 2600px;
    }

    .app-frame {
      min-height: 680px;
      height: 680px;
    }

    h2 {
      font-size: clamp(1.8rem, 9vw, 2.35rem);
      line-height: 0.98;
    }

    h3 {
      font-size: 1.2rem;
    }

    p,
    li {
      font-size: 0.98rem;
      line-height: 1.62;
    }

    .lede {
      margin-top: 1rem;
      font-size: 1.02rem;
    }

    .button,
    .contact-link,
    .card-link {
      min-height: 3rem;
      padding: 0.85rem 1.05rem;
    }

    .launch-card {
      max-width: none;
    }

    .button,
    .contact-link,
    .card-link {
      width: 100%;
    }

    h1 {
      max-width: 10ch;
    }
  }
</style>
